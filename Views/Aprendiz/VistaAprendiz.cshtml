        </div>
    </div>
</div>
<body>

    <!-- ═══ SIDEBAR ════════════════════════════════════════ -->
    <div class="sidebar" id="sidebar">
        <div class="sidebar-brand">
            <div class="sb-icon"><i class="bi bi-person-badge-fill"></i></div>
            <div class="sb-brand">
                <h1>SenaPay</h1>
                <span>Ecosistema Digital de Pagos</span>
            </div>
        </div>

        <div class="nav-section">Principal</div>
        <a class="nav-item active" href="#"><i class="bi bi-grid-fill"></i> Inicio</a>
        <a class="nav-item" href="#saldo"><i class="bi bi-wallet2"></i> Mi Billetera</a>
   

        <div class="nav-section">Gestión</div>
        <a class="nav-item" href="#movimientos"><i class="bi bi-clock-history"></i> Historial</a>
        <a class="nav-item" href="#"><i class="bi bi-qr-code-scan"></i> QR Pay</a>

        <div class="nav-section">Cuenta</div>
        <a class="nav-item" href="#"><i class="bi bi-person-lines-fill"></i> Mi Perfil</a>
        <a class="nav-item" href="#"><i class="bi bi-shield-lock-fill"></i> Seguridad</a>
        <a class="nav-item" href="#"><i class="bi bi-gear-fill"></i> Ajustes</a>

        <div class="sidebar-footer">
            <div class="sb-user" onclick="location.href='#'">
                <div class="sb-avatar">SC</div>
                <div class="sb-user-info">
                    <div class="sb-user-name">@nombre</div>
                    <div class="sb-user-role">@rol</div>
                </div>
                <i class="bi bi-three-dots" style="color:var(--text-muted);font-size:14px"></i>
            </div>
            <!-- ── Acciones rápidas ── -->
            <div class="sb-actions">
                <a class="sb-action-btn store" asp-controller="Store" asp-action="Index">
                    <i class="bi bi-shop-window"></i>
                    Ir a la Tienda
                </a>
                <button class="sb-action-btn logout" onclick="openLogout()">
                    <i class="bi bi-box-arrow-left"></i>
                    Cerrar sesión
                </button>
            </div>
        </div>
    </div>

    <!-- ═══ MAIN ════════════════════════════════════════════ -->
    <div class="shell">
        <main class="main">

            <!-- Topbar -->
            <div class="topbar">
                <div class="topbar-greeting">
                    <h2>Hola, @(nombre.Split(' ')[0]) 👋</h2>
                    <p>Bienvenido a tu espacio digital SENA</p>
                </div>
                <div class="topbar-actions">
                    <button class="icon-btn" onclick="toggleSidebar()" title="Menú">
                        <i class="bi bi-list"></i>
                    </button>
                    <a class="icon-btn" asp-controller="Store" asp-action="Index" title="Ir a la Tienda" style="display:grid;place-items:center;text-decoration:none">
                        <i class="bi bi-shop-window"></i>
                    </a>
                    <button class="icon-btn" title="Notificaciones" onclick="openNotif()">
                        <i class="bi bi-bell"></i>
                        <span class="notif-dot"></span>
                    </button>
                    <button class="icon-btn" onclick="openLogout()" title="Cerrar sesión" style="color:#dc2626;border-color:rgba(220,38,38,.2)">
                        <i class="bi bi-box-arrow-left"></i>
                    </button>
                </div>
            </div>

            <!-- ── CARNET SENA ─────────────────────────────────── -->
            <div class="carnet-wrap" id="carnetWrap">
                <div class="carnet" id="carnetCard">
                    <div class="carnet-stripe"></div>
                    <div class="carnet-inner">

                        <!-- Datos (izquierda) -->
                        <div class="carnet-data">
                            <div class="carnet-sena-logo">
                                <div class="sena-icon"><i class="bi bi-person-badge-fill"></i></div>
                                <span class="sena-label">SENA</span>
                            </div>
                            <div class="carnet-rol">@rol</div>
                            <div class="carnet-name">@nombre</div>
                            <div class="carnet-lastname">@apellidos</div>

                            <div class="carnet-fields">
                                <div class="cf-item">
                                    <div class="cf-label">Nº Id.</div>
                                    <div class="cf-value">@documento</div>
                                </div>
                                <div class="cf-item">
                                    <div class="cf-label">Rh.</div>
                                    <div class="cf-value">@rh</div>
                                </div>
                                <div class="cf-item">
                                    <div class="cf-label">No. Ficha</div>
                                    <div class="cf-value">@ficha</div>
                                </div>
                                <div class="cf-item">
                                    <div class="cf-label">Teléfono</div>
                                    <div class="cf-value">@telefono</div>
                                </div>
                                <div class="cf-item" style="grid-column:1/-1">
                                    <div class="cf-label">Correo</div>
                                    <div class="cf-value">@correo</div>
                                </div>
                            </div>

                            <!-- Barcode + programa -->
                            <div class="carnet-barcode">
                                <div class="barcode-lines" id="barcodeLines"></div>
                                <div class="carnet-prog">
                                    <div class="cp-main">@programa</div>
                                    <div class="cp-sub">@regional</div>
                                </div>
                            </div>
                        </div>

                        <!-- Foto (derecha, como el carnet físico) -->
                        <div class="carnet-photo">
                            <i class="bi bi-person-fill"></i>
                        </div>

                    </div>
                    <div class="carnet-bottom">
                        <span>Regional Boyacá</span>
                        <span>CIMM – Sogamoso</span>
                    </div>
                </div>
            </div>

            <!-- ── SALDO ───────────────────────────────────────── -->
            <div id="saldo"class="balance-card">
                <div class="bal-label">
                    Saldo disponible
                    <button class="eye-toggle" id="eyeBtn" onclick="toggleBalance()" title="Mostrar/ocultar saldo">
                        <i class="bi bi-eye" id="eyeIco"></i>
                    </button>
                </div>
                <div class="bal-amount" id="balAmount">@saldo</div>
                <div class="bal-actions">
                    <button class="bal-btn" onclick="openModal('transfer')">
                        <i class="bi bi-arrow-up-right"></i>
                        <span>Enviar</span>
                    </button>
                    <button class="bal-btn" onclick="openModal('receive')">
                        <i class="bi bi-arrow-down-left"></i>
                        <span>Recibir</span>
                    </button>
                    <button class="bal-btn" onclick="openModal('qr')">
                        <i class="bi bi-qr-code-scan"></i>
                        <span>QR</span>
                    </button>
                    <button class="bal-btn" onclick="openModal('pay')">
                        <i class="bi bi-lightning-charge-fill"></i>
                        <span>Pagar</span>
                    </button>
                </div>
            </div>

            <!-- ── WIDGETS ─────────────────────────────────────── -->
            <div class="widget-grid">
                <div class="widget">
                    <div class="wg-icon green"><i class="bi bi-arrow-down-circle-fill"></i></div>
                    <div class="wg-title">Ingresos este mes</div>
                    <div class="wg-value">$ 215.000</div>
                    <div class="wg-sub"><span class="wg-badge up">↑ 12%</span> vs mes anterior</div>
                </div>
                <div class="widget">
                    <div class="wg-icon blue"><i class="bi bi-send-fill"></i></div>
                    <div class="wg-title">Pagos realizados</div>
                    <div class="wg-value">$ 86.500</div>
                    <div class="wg-sub">4 transacciones</div>
                </div>
                <div class="widget">
                    <div class="wg-icon amber"><i class="bi bi-hourglass-split"></i></div>
                    <div class="wg-title">Pendientes</div>
                    <div class="wg-value">$ 12.000</div>
                    <div class="wg-sub"><span class="wg-badge pend">2 pendientes</span></div>
                </div>
                <div class="widget">
                    <div class="wg-icon violet"><i class="bi bi-star-fill"></i></div>
                    <div class="wg-title">Puntos SENA</div>
                    <div class="wg-value">1.240 pts</div>
                    <div class="wg-sub">Nivel Bronce</div>
                </div>
            </div>

            <!-- ── ÚLTIMOS MOVIMIENTOS ─────────────────────────── -->
            <div id="movimientos" class="section-title">
                Últimos movimientos
                <a class="see-all" href="#">Ver todos</a>
            </div>
            <div class="mov-list">
                <div class="mov-item">
                    <div class="mov-ico income"><i class="bi bi-arrow-down-left"></i></div>
                    <div class="mov-info">
                        <div class="mov-name">Subsidio de transporte</div>
                        <div class="mov-date">Hoy · 09:14 a. m.</div>
                    </div>
                    <div class="mov-amount income">+ $ 75.000</div>
                </div>
                <div class="mov-item">
                    <div class="mov-ico expense"><i class="bi bi-arrow-up-right"></i></div>
                    <div class="mov-info">
                        <div class="mov-name">Tienda Cafetería SENA</div>
                        <div class="mov-date">Ayer · 12:30 p. m.</div>
                    </div>
                    <div class="mov-amount expense">- $ 8.500</div>
                </div>
                <div class="mov-item">
                    <div class="mov-ico income"><i class="bi bi-arrow-down-left"></i></div>
                    <div class="mov-info">
                        <div class="mov-name">Apoyo de sostenimiento</div>
                        <div class="mov-date">10 may · 08:00 a. m.</div>
                    </div>
                    <div class="mov-amount income">+ $ 140.000</div>
                </div>
                <div class="mov-item">
                    <div class="mov-ico expense"><i class="bi bi-arrow-up-right"></i></div>
                    <div class="mov-info">
                        <div class="mov-name">Fotocopias Centro CIMM</div>
                        <div class="mov-date">9 may · 03:45 p. m.</div>
                    </div>
                    <div class="mov-amount expense">- $ 3.500</div>
                </div>
                <div class="mov-item">
                    <div class="mov-ico pending"><i class="bi bi-hourglass-split"></i></div>
                    <div class="mov-info">
                        <div class="mov-name">Pago instructor – Pendiente</div>
                        <div class="mov-date">8 may · En proceso</div>
                    </div>
                    <div class="mov-amount pending">$ 12.000</div>
                </div>
            </div>

        </main>
    </div>

    <!-- ═══ BOTTOM NAV (mobile) ════════════════════════════ -->
    <nav class="bottom-nav">
        <div class="bn-items">
            <a class="bn-item active" href="#"><i class="bi bi-grid-fill"></i>Inicio</a>
            <a class="bn-item" href="#"><i class="bi bi-wallet2"></i>Billetera</a>
            <a class="bn-item" onclick="openModal('transfer')"><i class="bi bi-arrow-left-right"></i>Transferir</a>
            <a class="bn-item" href="#"><i class="bi bi-clock-history"></i>Historial</a>
            <a class="bn-item" href="#"><i class="bi bi-person-fill"></i>Perfil</a>
        </div>
    </nav>

    <!-- ═══ MODAL SHEET ════════════════════════════════════ -->
    <div class="modal-backdrop" id="modalBackdrop" onclick="closeModalOutside(event)">
        <div class="modal-sheet">
            <div class="modal-handle"></div>
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:18px">
                <div class="modal-title" id="modalTitle">Enviar dinero</div>
                <button class="m-close" onclick="closeModal()"><i class="bi bi-x-lg"></i></button>
            </div>
            <div id="modalBody">
                <div class="m-field">
                    <label class="m-label">Documento destinatario</label>
                    <input class="m-input" type="text" placeholder="Número de documento" onkeypress="return isNum(event)">
                </div>
                <div class="m-field">
                    <label class="m-label">Monto (COP)</label>
                    <input class="m-input" type="text" placeholder="$ 0">
                </div>
                <div class="m-field">
                    <label class="m-label">Concepto</label>
                    <input class="m-input" type="text" placeholder="Descripción opcional">
                </div>
                <button class="m-btn">Confirmar envío</button>
            </div>
        </div>
    </div>

    <script>
        /* ── BARCODE GENERADO ─────────────────────────────── */
        (function(){
          const c=document.getElementById('barcodeLines');
          if(!c)return;
          const w=[1,2,1,3,1,2,3,1,2,1,3,2,1,1,3,2,1,2,1,3,1,2,1,2,3,1,1,2,3,1,2,1,2,3,1,2];
          w.forEach(n=>{const b=document.createElement('span');b.style.cssText=`width:${n}px;height:${12+Math.random()*4}px;`;c.appendChild(b)});
        })();

        /* ── TOGGLE SALDO ────────────────────────────────── */
        let balVisible=true;
        const realAmount='@saldo';
        function toggleBalance(){
          balVisible=!balVisible;
          document.getElementById('balAmount').textContent=balVisible?realAmount:'$ •••.•••';
          document.getElementById('eyeIco').className=balVisible?'bi bi-eye':'bi bi-eye-slash';
        }

        /* ── SIDEBAR TOGGLE ──────────────────────────────── */
        function toggleSidebar(){document.getElementById('sidebar').classList.toggle('open')}

        /* ── TILT CARNET ─────────────────────────────────── */
        const carnet=document.getElementById('carnetCard');
        let tx=0,ty=0,ttx=0,tty=0;
        document.getElementById('carnetWrap').addEventListener('mousemove',e=>{
          const r=carnet.getBoundingClientRect();
          ttx=(e.clientY-r.top-r.height/2)/r.height*-6;
          tty=(e.clientX-r.left-r.width/2)/r.width*6;
        });
        document.getElementById('carnetWrap').addEventListener('mouseleave',()=>{ttx=0;tty=0});
        function lerp(a,b,t){return a+(b-a)*t}
        (function loop(){
          tx=lerp(tx,ttx,.08);ty=lerp(ty,tty,.08);
          carnet.style.transform=`perspective(800px) rotateX(${tx.toFixed(2)}deg) rotateY(${ty.toFixed(2)}deg)`;
          requestAnimationFrame(loop);
        })();

        /* ── MODALES PRINCIPALES ─────────────────────────── */
        const modals={
          transfer:{title:'Enviar dinero',body:`
            <div class="m-field"><label class="m-label">Documento destinatario</label><input class="m-input" type="text" placeholder="Número de documento" onkeypress="return isNum(event)"></div>
            <div class="m-field"><label class="m-label">Monto (COP)</label><input class="m-input" type="text" placeholder="$ 0"></div>
            <div class="m-field"><label class="m-label">Concepto</label><input class="m-input" type="text" placeholder="Descripción opcional"></div>
            <button class="m-btn">Confirmar envío</button>`},
          receive:{title:'Recibir dinero',body:`
            <div style="text-align:center;padding:10px 0 20px">
              <div style="width:80px;height:80px;border-radius:20px;background:var(--cr);display:grid;place-items:center;font-size:36px;color:var(--c);margin:0 auto 14px"><i class="bi bi-arrow-down-left"></i></div>
              <div style="font-family:'Outfit',sans-serif;font-size:1rem;font-weight:800;color:var(--text-primary)">Tu número de cobro</div>
              <div style="font-family:'Outfit',sans-serif;font-size:1.8rem;font-weight:800;color:var(--c);margin:8px 0">@documento</div>
              <div style="font-size:.75rem;color:var(--text-muted)">Comparte este número para recibir pagos</div>
            </div>
            <button class="m-btn" onclick="copyAndToast('@documento')">Copiar número</button>`},
          qr:{title:'Mi código QR',body:`
            <div style="text-align:center;padding:10px 0 20px">
              <div style="width:140px;height:140px;border-radius:18px;background:var(--input-bg);border:2px solid var(--divider);display:grid;place-items:center;margin:0 auto 16px;font-size:70px;color:var(--text-muted)"><i class="bi bi-qr-code"></i></div>
              <div style="font-size:.78rem;color:var(--text-secondary)">Muestra este QR para recibir pagos al instante</div>
            </div>
            <button class="m-btn">Descargar QR</button>`},
          pay:{title:'Pagar servicio',body:`
            <div class="m-field"><label class="m-label">Tipo de pago</label><select class="m-input"><option>Cafetería</option><option>Materiales</option><option>Inscripción</option><option>Otro</option></select></div>
            <div class="m-field"><label class="m-label">Monto (COP)</label><input class="m-input" type="text" placeholder="$ 0"></div>
            <button class="m-btn">Pagar ahora</button>`}
        };
        function openModal(type){
          const m=modals[type];
          document.getElementById('modalTitle').textContent=m.title;
          document.getElementById('modalBody').innerHTML=m.body;
          document.getElementById('modalBackdrop').classList.add('open');
        }
        function closeModal(){document.getElementById('modalBackdrop').classList.remove('open')}
        function closeModalOutside(e){if(e.target===document.getElementById('modalBackdrop'))closeModal()}
        function isNum(e){const c=e.which||e.keyCode;return c>=48&&c<=57}

        /* ── WIDGETS ─────────────────────────────────────── */
        const widgetActions=['transfer','transfer','transfer',''];
        document.querySelectorAll('.widget').forEach((el,i)=>{
          el.addEventListener('click',()=>{
            const actions=['transfer','pay','pay',''];
            const titles=['Ingresos del mes','Pagos realizados','Pagos pendientes',''];
            if(i===3){
              showToast('1.240 puntos SENA · Nivel Bronce 🥉');return;
            }
            openModal(i===0?'receive':i===1?'pay':'pay');
          });
        });

        /* ── MOVIMIENTOS DETALLE ─────────────────────────── */
        const movimientos=[
          {ico:'income',icoCls:'bi-arrow-down-left',nombre:'Subsidio de transporte',fecha:'Hoy · 09:14 a. m.',monto:'+ $ 75.000',tipo:'Ingreso',estado:'Completado',ref:'TXN-20240512-001',categoria:'Subsidio SENA'},
          {ico:'expense',icoCls:'bi-arrow-up-right',nombre:'Tienda Cafetería SENA',fecha:'Ayer · 12:30 p. m.',monto:'- $ 8.500',tipo:'Egreso',estado:'Completado',ref:'TXN-20240511-003',categoria:'Alimentación'},
          {ico:'income',icoCls:'bi-arrow-down-left',nombre:'Apoyo de sostenimiento',fecha:'10 may · 08:00 a. m.',monto:'+ $ 140.000',tipo:'Ingreso',estado:'Completado',ref:'TXN-20240510-001',categoria:'Apoyo SENA'},
          {ico:'expense',icoCls:'bi-arrow-up-right',nombre:'Fotocopias Centro CIMM',fecha:'9 may · 03:45 p. m.',monto:'- $ 3.500',tipo:'Egreso',estado:'Completado',ref:'TXN-20240509-007',categoria:'Papelería'},
          {ico:'pending',icoCls:'bi-hourglass-split',nombre:'Pago instructor – Pendiente',fecha:'8 may · En proceso',monto:'$ 12.000',tipo:'Egreso',estado:'Pendiente',ref:'TXN-20240508-002',categoria:'Pago SENA'}
        ];

        document.querySelectorAll('.mov-item').forEach((el,i)=>{
          el.addEventListener('click',()=>{
            const m=movimientos[i];
            const colorMap={income:'#16a34a',expense:'#dc2626',pending:'#d97706'};
            const bgMap={income:'rgba(34,197,94,.1)',expense:'rgba(239,68,68,.1)',pending:'rgba(245,158,11,.1)'};
            document.getElementById('movModalTitle').textContent='Detalle del movimiento';
            document.getElementById('movModalBody').innerHTML=`
              <div style="text-align:center;margin-bottom:20px">
                <div style="width:64px;height:64px;border-radius:18px;background:${bgMap[m.ico]};display:grid;place-items:center;font-size:28px;color:${colorMap[m.ico]};margin:0 auto 12px"><i class="bi ${m.icoCls}"></i></div>
                <div style="font-family:'Outfit',sans-serif;font-size:1.5rem;font-weight:800;color:${colorMap[m.ico]}">${m.monto}</div>
                <div style="font-size:.82rem;color:var(--text-secondary);margin-top:4px">${m.nombre}</div>
              </div>
              <div style="background:var(--input-bg);border-radius:14px;padding:16px;display:grid;gap:10px">
                ${row('Tipo',m.tipo)}
                ${row('Fecha',m.fecha)}
                ${row('Estado','<span style="font-size:.72rem;font-weight:700;padding:3px 10px;border-radius:100px;background:'+(m.estado==='Completado'?'rgba(34,197,94,.12)':'rgba(245,158,11,.12)')+';color:'+(m.estado==='Completado'?'#16a34a':'#d97706')+'">'+m.estado+'</span>')}
                ${row('Categoría',m.categoria)}
                ${row('Referencia','<span style="font-size:.75rem;font-family:monospace;color:var(--text-muted)">'+m.ref+'</span>')}
              </div>
              <button class="m-btn" style="margin-top:16px" onclick="copyAndToast('${m.ref}')">Copiar referencia</button>`;
            document.getElementById('movModalBackdrop').classList.add('open');
          });
        });
        function row(label,value){
          return `<div style="display:flex;justify-content:space-between;align-items:center;font-size:.8rem">
            <span style="color:var(--text-muted);font-weight:500">${label}</span>
            <span style="color:var(--text-primary);font-weight:600">${value}</span>
          </div>`;
        }
        function closeMov(){document.getElementById('movModalBackdrop').classList.remove('open')}

        /* ── NOTIFICACIONES ──────────────────────────────── */
        const notificaciones=[
          {ico:'bi-arrow-down-left',color:'#16a34a',bg:'rgba(34,197,94,.1)',titulo:'Subsidio recibido',desc:'Se acreditaron $ 75.000 a tu cuenta.',hora:'Hace 2 horas',leida:false},
          {ico:'bi-hourglass-split',color:'#d97706',bg:'rgba(245,158,11,.1)',titulo:'Pago pendiente',desc:'Tienes un pago de $ 12.000 en proceso.',hora:'Hace 1 día',leida:false},
          {ico:'bi-shield-lock-fill',color:'#3b82f6',bg:'rgba(59,130,246,.1)',titulo:'Inicio de sesión',desc:'Acceso desde nuevo dispositivo detectado.',hora:'Hace 2 días',leida:true},
          {ico:'bi-star-fill',color:'#8b5cf6',bg:'rgba(139,92,246,.1)',titulo:'Puntos acumulados',desc:'Ganaste 120 puntos SENA este mes.',hora:'Hace 3 días',leida:true}
        ];

        function openNotif(){
          const list=document.getElementById('notifList');
          list.innerHTML=notificaciones.map((n,i)=>`
            <div onclick="markRead(${i})" id="notif-${i}" style="display:flex;gap:12px;padding:14px 22px;border-bottom:1px solid var(--divider);cursor:pointer;transition:background .18s;background:${n.leida?'transparent':'var(--cr)'}" onmouseover="this.style.background='var(--input-bg)'" onmouseout="this.style.background='${n.leida?'transparent':'var(--cr)'}'">
              <div style="width:40px;height:40px;border-radius:13px;background:${n.bg};display:grid;place-items:center;font-size:17px;color:${n.color};flex-shrink:0"><i class="bi ${n.ico}"></i></div>
              <div style="flex:1;min-width:0">
                <div style="font-size:.83rem;font-weight:${n.leida?'500':'700'};color:var(--text-primary);font-family:'Inter',sans-serif">${n.titulo}</div>
                <div style="font-size:.74rem;color:var(--text-secondary);margin-top:2px;line-height:1.4">${n.desc}</div>
                <div style="font-size:.66rem;color:var(--text-muted);margin-top:4px">${n.hora}</div>
              </div>
              ${!n.leida?`<div style="width:8px;height:8px;border-radius:50%;background:#ef4444;margin-top:6px;flex-shrink:0"></div>`:''}
            </div>`).join('');
          document.getElementById('notifBackdrop').classList.add('open');
        }
        function closeNotif(){document.getElementById('notifBackdrop').classList.remove('open')}
        function markRead(i){
          notificaciones[i].leida=true;
          const el=document.getElementById(`notif-${i}`);
          if(el){
            el.style.background='transparent';
            el.style.fontWeight='500';
            const dot=el.querySelector('div[style*="border-radius:50%"]');
            if(dot)dot.remove();
          }
          const unread=notificaciones.filter(n=>!n.leida).length;
          const dot=document.querySelector('.notif-dot');
          if(dot)dot.style.display=unread>0?'block':'none';
        }

        /* ── TOAST ───────────────────────────────────────── */
        function showToast(msg){
          let t=document.getElementById('toastEl');
          if(!t){
            t=document.createElement('div');
            t.id='toastEl';
            t.style.cssText='position:fixed;bottom:100px;left:50%;transform:translateX(-50%) translateY(20px);background:var(--text-primary);color:var(--panel);font-family:"Outfit",sans-serif;font-size:.78rem;font-weight:600;padding:10px 20px;border-radius:100px;z-index:9999;opacity:0;transition:all .3s;pointer-events:none;white-space:nowrap';
            document.body.appendChild(t);
          }
          t.textContent=msg;
          t.style.opacity='1';t.style.transform='translateX(-50%) translateY(0)';
          clearTimeout(t._tid);
          t._tid=setTimeout(()=>{t.style.opacity='0';t.style.transform='translateX(-50%) translateY(20px)'},2500);
        }
        function copyAndToast(text){
          if(navigator.clipboard)navigator.clipboard.writeText(text).then(()=>showToast('¡Copiado al portapapeles!'));
          else showToast('¡Copiado: '+text);
        }

        /* ── LOGOUT CONFIRM ──────────────────────────────── */
        function openLogout(){document.getElementById('logoutBackdrop').classList.add('open')}
        function closeLogout(){document.getElementById('logoutBackdrop').classList.remove('open')}
        function confirmLogout(){window.location.href='/Account/Logout'}
    </script>

    <!-- ═══ MODAL LOGOUT ════════════════════════════════════ -->
    <div class="confirm-backdrop" id="logoutBackdrop" onclick="if(event.target===this)closeLogout()">
        <div class="confirm-card">
            <div class="confirm-ico"><i class="bi bi-box-arrow-left"></i></div>
            <div class="confirm-title">¿Cerrar sesión?</div>
            <div class="confirm-desc">Se cerrará tu sesión activa en SenaPay. Podrás volver a ingresar cuando quieras.</div>
            <div class="confirm-actions">
                <button class="confirm-cancel" onclick="closeLogout()">Cancelar</button>
                <button class="confirm-ok" onclick="confirmLogout()">Sí, salir</button>
            </div>
        </div>
    </div>

</body>
</html>
