}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>SenaPay | Dashboard</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        /* ─── RESET & TOKENS ──────────────────────────────────── */
        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0
        }

        :root {
            --c: #39A900;
            --cg: rgba(57,169,0,.18);
            --cr: rgba(57,169,0,.07);
            --speed: .5s;
            --bg: #f0f4f8;
            --panel: #ffffff;
            --card: #ffffff;
            --card-border: rgba(0,0,0,.07);
            --text-primary: #0f1923;
            --text-secondary: #64748b;
            --text-muted: #94a3b8;
            --divider: #e9eef4;
            --input-bg: #f4f7fa;
            --input-border: #e2e8f0;
            --nav-bg: #ffffff;
            --nav-border: rgba(0,0,0,.06);
            --shadow: 0 4px 28px rgba(0,0,0,.07),0 1px 4px rgba(0,0,0,.04);
            --shadow-card: 0 2px 16px rgba(0,0,0,.06),0 1px 3px rgba(0,0,0,.04);
        }

        @@media (prefers-color-scheme:dark) {
            :root {
                --bg: #060608;
                --panel: #0e0e12;
                --card: #141418;
                --card-border: rgba(255,255,255,.06);
                --text-primary: #f1f5f9;
                --text-secondary: #94a3b8;
                --text-muted: #475569;
                --divider: #1e1e24;
                --input-bg: #1a1a20;
                --input-border: #252530;
                --nav-bg: #0e0e12;
                --nav-border: rgba(255,255,255,.05);
                --shadow: 0 4px 28px rgba(0,0,0,.4),0 1px 4px rgba(0,0,0,.3);
                --shadow-card: 0 2px 16px rgba(0,0,0,.35),0 1px 3px rgba(0,0,0,.2);
            }
        }

        html, body {
            height: 100%;
            font-family: 'Inter',sans-serif;
            background: var(--bg);
            color: var(--text-primary);
            -webkit-font-smoothing: antialiased;
            overflow-x: hidden
        }

        /* ─── SHELL ───────────────────────────────────────────── */
        .shell {
            display: flex;
            min-height: 100vh;
            padding-bottom: 80px
        }

        /* ─── SIDEBAR ─────────────────────────────────────────── */
        .sidebar {
            width: 260px;
            min-width: 260px;
            background: var(--panel);
            border-right: 1px solid var(--nav-border);
            display: flex;
            flex-direction: column;
            position: fixed;
            top: 0;
            left: 0;
            bottom: 0;
            z-index: 50;
            transition: transform .35s cubic-bezier(.22,1,.36,1);
            overflow-y: auto;
        }

        .sidebar-brand {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 28px 22px 22px;
            border-bottom: 1px solid var(--divider);
        }

        .sb-icon {
            width: 42px;
            height: 42px;
            border-radius: 13px;
            background: var(--c);
            display: grid;
            place-items: center;
            color: #fff;
            font-size: 18px;
            box-shadow: 0 6px 18px var(--cg);
            flex-shrink: 0;
        }

        .sb-brand h1 {
            font-family: 'Outfit',sans-serif;
            font-size: 1.35rem;
            font-weight: 800;
            color: var(--text-primary);
            letter-spacing: -.4px;
            line-height: 1
        }

        .sb-brand span {
            font-size: .65rem;
            color: var(--text-muted);
            letter-spacing: .5px;
            display: block;
            margin-top: 3px
        }

        .nav-section {
            padding: 18px 14px 6px;
            font-size: .62rem;
            font-weight: 700;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 1.4px;
            font-family: 'Outfit',sans-serif
        }

        .nav-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 11px 16px;
            border-radius: 12px;
            margin: 2px 8px;
            color: var(--text-secondary);
            font-size: .84rem;
            font-weight: 500;
            cursor: pointer;
            text-decoration: none;
            transition: all .2s;
            font-family: 'Inter',sans-serif;
        }

            .nav-item i {
                font-size: 16px;
                width: 18px;
                text-align: center
            }

            .nav-item:hover, .nav-item.active {
                background: var(--cr);
                color: var(--c)
            }

            .nav-item.active {
                font-weight: 600
            }

        .nav-badge {
            margin-left: auto;
            background: var(--c);
            color: #fff;
            font-size: .6rem;
            font-weight: 700;
            border-radius: 100px;
            padding: 2px 7px;
            font-family: 'Outfit',sans-serif
        }

        .sidebar-footer {
            margin-top: auto;
            padding: 16px 10px;
            border-top: 1px solid var(--divider)
        }

        .sb-user {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px 12px;
            border-radius: 12px;
            cursor: pointer;
            transition: background .2s
        }

            .sb-user:hover {
                background: var(--input-bg)
            }

        .sb-avatar {
            width: 36px;
            height: 36px;
            border-radius: 11px;
            background: var(--c);
            display: grid;
            place-items: center;
            color: #fff;
            font-size: 13px;
            font-weight: 700;
            font-family: 'Outfit',sans-serif;
            flex-shrink: 0
        }

        .sb-user-info {
            flex: 1;
            min-width: 0
        }

        .sb-user-name {
            font-size: .78rem;
            font-weight: 600;
            color: var(--text-primary);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            font-family: 'Outfit',sans-serif
        }

        .sb-user-role {
            font-size: .65rem;
            color: var(--text-muted);
            margin-top: 1px
        }

        /* ─── MAIN ────────────────────────────────────────────── */
        .main {
            flex: 1;
            margin-left: 260px;
            padding: 32px 28px;
            max-width: 900px;
            width: 100%
        }

        /* ─── TOP BAR ─────────────────────────────────────────── */
        .topbar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 30px
        }

        .topbar-greeting h2 {
            font-family: 'Outfit',sans-serif;
            font-size: 1.5rem;
            font-weight: 800;
            color: var(--text-primary);
            letter-spacing: -.5px
        }

        .topbar-greeting p {
            font-size: .82rem;
            color: var(--text-secondary);
            margin-top: 3px
        }

        .topbar-actions {
            display: flex;
            gap: 10px
        }

        .icon-btn {
            width: 40px;
            height: 40px;
            border-radius: 12px;
            border: 1px solid var(--card-border);
            background: var(--card);
            display: grid;
            place-items: center;
            cursor: pointer;
            color: var(--text-secondary);
            font-size: 16px;
            box-shadow: var(--shadow-card);
            transition: all .2s;
            position: relative;
        }

            .icon-btn:hover {
                color: var(--c);
                border-color: var(--c)
            }

        .notif-dot {
            position: absolute;
            top: 8px;
            right: 8px;
            width: 7px;
            height: 7px;
            border-radius: 50%;
            background: #ef4444;
            border: 2px solid var(--card)
        }

        /* ─── CARNET CARD ─────────────────────────────────────── */
        .carnet-wrap {
            perspective: 1000px;
            margin-bottom: 24px
        }

        .carnet {
            background: var(--card);
            border-radius: 24px;
            border: 1px solid var(--card-border);
            box-shadow: var(--shadow);
            overflow: hidden;
            position: relative;
            transform-style: preserve-3d;
            animation: slideUp .7s cubic-bezier(.22,1,.36,1) both;
        }

        @@keyframes slideUp {
            from {
                opacity: 0;
                transform: translateY(24px)
            }

            to {
                opacity: 1;
                transform: translateY(0)
            }
        }

        /* Franja superior verde estilo SENA */
        .carnet-stripe {
            background: var(--c);
            height: 8px;
            width: 100%;
        }

        .carnet-inner {
            padding: 24px 28px 22px;
            display: flex;
            gap: 22px;
            align-items: flex-start
        }

        /* Avatar / foto */
        .carnet-photo {
            width: 90px;
            height: 110px;
            border-radius: 12px;
            background: linear-gradient(145deg,#e2eaef,#cfd9e0);
            display: grid;
            place-items: center;
            flex-shrink: 0;
            border: 2px solid var(--divider);
            overflow: hidden;
            position: relative;
        }

        @@media (prefers-color-scheme:dark) {
            .carnet-photo {
                background: linear-gradient(145deg,#1e2028,#16181f);
                border-color: #252530
            }
        }

        .carnet-photo i {
            font-size: 42px;
            color: var(--text-muted)
        }

        /* Logo SENA en carnet */
        .carnet-sena-logo {
            display: flex;
            flex-direction: row;
            align-items: center;
            gap: 6px;
            margin-bottom: 10px;
        }

        .sena-icon {
            width: 26px;
            height: 26px;
            background: var(--c);
            border-radius: 50%;
            display: grid;
            place-items: center;
            color: #fff;
            font-size: 12px;
            flex-shrink: 0
        }

        .sena-label {
            font-family: 'Outfit',sans-serif;
            font-size: .75rem;
            font-weight: 800;
            color: var(--c);
            letter-spacing: 1px
        }

        /* Datos carnet */
        .carnet-data {
            flex: 1;
            min-width: 0
        }

        .carnet-rol {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            font-size: .65rem;
            font-weight: 700;
            color: var(--c);
            text-transform: uppercase;
            letter-spacing: 1px;
            font-family: 'Outfit',sans-serif;
            margin-bottom: 6px;
        }

            .carnet-rol::before {
                content: '';
                width: 16px;
                height: 2px;
                background: var(--c);
                border-radius: 2px
            }

        .carnet-name {
            font-family: 'Outfit',sans-serif;
            font-weight: 800;
            font-size: 1.15rem;
            color: var(--c);
            line-height: 1.15;
            letter-spacing: -.3px
        }

        .carnet-lastname {
            font-family: 'Outfit',sans-serif;
            font-weight: 700;
            font-size: .95rem;
            color: var(--text-primary);
            margin-bottom: 12px;
            letter-spacing: -.2px
        }

        .carnet-fields {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 7px 16px;
            margin-bottom: 14px
        }

        .cf-item {
        }

        .cf-label {
            font-size: .6rem;
            font-weight: 700;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 1px;
            font-family: 'Outfit',sans-serif
        }

        .cf-value {
            font-size: .82rem;
            font-weight: 600;
            color: var(--text-primary);
            font-family: 'Inter',sans-serif;
            margin-top: 1px
        }

        /* Barcode area */
        .carnet-barcode {
            display: flex;
            align-items: center;
            gap: 10px;
            padding-top: 14px;
            border-top: 1px solid var(--divider);
        }

        .barcode-lines {
            display: flex;
            gap: 1.5px;
            align-items: center;
            flex: 1
        }

            .barcode-lines span {
                display: block;
                background: var(--text-primary);
                border-radius: 1px;
                animation: none
            }

        .carnet-prog {
            flex: 0 0 auto;
            text-align: right
        }

        .cp-main {
            font-family: 'Outfit',sans-serif;
            font-size: .68rem;
            font-weight: 700;
            color: var(--text-primary);
            text-transform: uppercase;
            letter-spacing: .4px;
            line-height: 1.3
        }

        .cp-sub {
            font-size: .62rem;
            color: var(--text-muted);
            margin-top: 2px
        }

        /* Franja inferior */
        .carnet-bottom {
            background: var(--c);
            padding: 8px 28px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

            .carnet-bottom span {
                font-family: 'Outfit',sans-serif;
                font-size: .67rem;
                font-weight: 700;
                color: rgba(255,255,255,.85);
                letter-spacing: .4px
            }

        /* ─── SALDO CARD ──────────────────────────────────────── */
        .balance-card {
            background: var(--c);
            border-radius: 20px;
            padding: 22px 24px;
            margin-bottom: 20px;
            position: relative;
            overflow: hidden;
            box-shadow: 0 8px 32px var(--cg);
            animation: slideUp .7s .1s cubic-bezier(.22,1,.36,1) both;
        }

            .balance-card::before {
                content: '';
                position: absolute;
                top: -40px;
                right: -40px;
                width: 180px;
                height: 180px;
                border-radius: 50%;
                background: rgba(255,255,255,.07);
                pointer-events: none;
            }

            .balance-card::after {
                content: '';
                position: absolute;
                bottom: -60px;
                right: 40px;
                width: 130px;
                height: 130px;
                border-radius: 50%;
                background: rgba(255,255,255,.05);
                pointer-events: none;
            }

        .bal-label {
            font-size: .68rem;
            font-weight: 600;
            color: rgba(255,255,255,.7);
            text-transform: uppercase;
            letter-spacing: 1.2px;
            font-family: 'Outfit',sans-serif;
            display: flex;
            align-items: center;
            gap: 8px
        }

        .eye-toggle {
            background: none;
            border: none;
            color: rgba(255,255,255,.6);
            font-size: 14px;
            cursor: pointer;
            padding: 0;
            transition: color .2s
        }

            .eye-toggle:hover {
                color: #fff
            }

        .bal-amount {
            font-family: 'Outfit',sans-serif;
            font-size: 2.4rem;
            font-weight: 800;
            color: #fff;
            letter-spacing: -1.5px;
            margin: 8px 0 20px;
            line-height: 1;
        }

        .bal-actions {
            display: flex;
            gap: 10px;
            position: relative;
            z-index: 1
        }

        .bal-btn {
            flex: 1;
            background: rgba(255,255,255,.15);
            border: 1px solid rgba(255,255,255,.2);
            border-radius: 12px;
            padding: 10px 8px;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 5px;
            cursor: pointer;
            transition: all .2s;
            color: #fff;
            text-decoration: none;
        }

            .bal-btn:hover {
                background: rgba(255,255,255,.25)
            }

            .bal-btn i {
                font-size: 18px
            }

            .bal-btn span {
                font-size: .65rem;
                font-weight: 600;
                font-family: 'Outfit',sans-serif;
                letter-spacing: .3px
            }

        /* ─── GRID WIDGETS ────────────────────────────────────── */
        .widget-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 14px;
            margin-bottom: 20px;
            animation: slideUp .7s .2s cubic-bezier(.22,1,.36,1) both
        }

        .widget {
            background: var(--card);
            border-radius: 18px;
            padding: 18px 20px;
            border: 1px solid var(--card-border);
            box-shadow: var(--shadow-card);
            cursor: pointer;
            transition: all .25s;
        }

            .widget:hover {
                transform: translateY(-2px);
                box-shadow: var(--shadow)
            }

        .wg-icon {
            width: 40px;
            height: 40px;
            border-radius: 12px;
            display: grid;
            place-items: center;
            font-size: 18px;
            margin-bottom: 12px;
        }

            .wg-icon.green {
                background: var(--cr);
                color: var(--c)
            }

            .wg-icon.blue {
                background: rgba(59,130,246,.1);
                color: #3b82f6
            }

            .wg-icon.amber {
                background: rgba(245,158,11,.1);
                color: #f59e0b
            }

            .wg-icon.violet {
                background: rgba(139,92,246,.1);
                color: #8b5cf6
            }

        .wg-title {
            font-size: .78rem;
            font-weight: 500;
            color: var(--text-secondary);
            font-family: 'Inter',sans-serif
        }

        .wg-value {
            font-family: 'Outfit',sans-serif;
            font-size: 1.15rem;
            font-weight: 800;
            color: var(--text-primary);
            margin-top: 3px;
            letter-spacing: -.3px
        }

        .wg-sub {
            font-size: .67rem;
            color: var(--text-muted);
            margin-top: 4px;
            display: flex;
            align-items: center;
            gap: 4px
        }

        .wg-badge {
            font-size: .6rem;
            font-weight: 700;
            padding: 2px 7px;
            border-radius: 100px
        }

            .wg-badge.up {
                background: rgba(34,197,94,.12);
                color: #16a34a
            }

            .wg-badge.pend {
                background: rgba(245,158,11,.12);
                color: #d97706
            }

        /* ─── MOVIMIENTOS ─────────────────────────────────────── */
        .section-title {
            font-family: 'Outfit',sans-serif;
            font-size: 1rem;
            font-weight: 800;
            color: var(--text-primary);
            letter-spacing: -.3px;
            margin-bottom: 14px;
            display: flex;
            align-items: center;
            justify-content: space-between
        }

        .see-all {
            font-size: .73rem;
            font-weight: 500;
            color: var(--c);
            cursor: pointer;
            text-decoration: none
        }

        .mov-list {
            background: var(--card);
            border-radius: 18px;
            border: 1px solid var(--card-border);
            box-shadow: var(--shadow-card);
            overflow: hidden;
            animation: slideUp .7s .3s cubic-bezier(.22,1,.36,1) both;
        }

        .mov-item {
            display: flex;
            align-items: center;
            gap: 14px;
            padding: 14px 18px;
            border-bottom: 1px solid var(--divider);
            transition: background .18s;
            cursor: pointer;
        }

            .mov-item:last-child {
                border-bottom: none
            }

            .mov-item:hover {
                background: var(--input-bg)
            }

        .mov-ico {
            width: 40px;
            height: 40px;
            border-radius: 13px;
            display: grid;
            place-items: center;
            font-size: 17px;
            flex-shrink: 0;
        }

            .mov-ico.income {
                background: rgba(34,197,94,.1);
                color: #16a34a
            }

            .mov-ico.expense {
                background: rgba(239,68,68,.1);
                color: #dc2626
            }

            .mov-ico.pending {
                background: rgba(245,158,11,.1);
                color: #d97706
            }

        .mov-info {
            flex: 1;
            min-width: 0
        }

        .mov-name {
            font-size: .84rem;
            font-weight: 600;
            color: var(--text-primary);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            font-family: 'Inter',sans-serif
        }

        .mov-date {
            font-size: .67rem;
            color: var(--text-muted);
            margin-top: 2px
        }

        .mov-amount {
            font-family: 'Outfit',sans-serif;
            font-size: .95rem;
            font-weight: 700;
            letter-spacing: -.2px;
            white-space: nowrap
        }

            .mov-amount.income {
                color: #16a34a
            }

            .mov-amount.expense {
                color: #dc2626
            }

            .mov-amount.pending {
                color: #d97706
            }

        /* ─── BOTTOM NAV (mobile) ─────────────────────────────── */
        .bottom-nav {
            display: none;
            position: fixed;
            bottom: 0;
            left: 0;
            right: 0;
            background: var(--nav-bg);
            border-top: 1px solid var(--nav-border);
            padding: 10px 0 14px;
            z-index: 100;
        }

        .bn-items {
            display: flex;
            justify-content: space-around
        }

        .bn-item {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 4px;
            font-size: .6rem;
            font-weight: 600;
            color: var(--text-muted);
            font-family: 'Outfit',sans-serif;
            cursor: pointer;
            transition: color .2s;
            min-width: 50px;
            text-decoration: none;
        }

            .bn-item i {
                font-size: 20px
            }

            .bn-item.active {
                color: var(--c)
            }

        /* ─── MODAL QUICK TRANSFER ────────────────────────────── */
        .modal-backdrop {
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,.45);
            backdrop-filter: blur(6px);
            z-index: 200;
            display: none;
            align-items: flex-end;
            justify-content: center;
        }

            .modal-backdrop.open {
                display: flex
            }

        .modal-sheet {
            background: var(--panel);
            border-radius: 24px 24px 0 0;
            width: 100%;
            max-width: 480px;
            padding: 28px 24px 36px;
            animation: sheetUp .38s cubic-bezier(.22,1,.36,1) both;
        }

        @@keyframes sheetUp {
            from {
                transform: translateY(100%)
            }

            to {
                transform: translateY(0)
            }
        }

        .modal-handle {
            width: 40px;
            height: 4px;
            border-radius: 4px;
            background: var(--divider);
            margin: 0 auto 22px
        }

        .modal-title {
            font-family: 'Outfit',sans-serif;
            font-size: 1.1rem;
            font-weight: 800;
            color: var(--text-primary);
            margin-bottom: 20px
        }

        .m-field {
            margin-bottom: 14px
        }

        .m-label {
            font-size: .65rem;
            font-weight: 700;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 1.1px;
            font-family: 'Outfit',sans-serif;
            display: block;
            margin-bottom: 6px
        }

        .m-input {
            width: 100%;
            padding: 13px 15px;
            border: 1.5px solid var(--input-border);
            border-radius: 12px;
            font-family: 'Inter',sans-serif;
            font-size: .88rem;
            color: var(--text-primary);
            background: var(--input-bg);
            outline: none;
            transition: border-color .25s,box-shadow .25s;
        }

            .m-input:focus {
                border-color: var(--c);
                box-shadow: 0 0 0 3px var(--cr)
            }

        .m-btn {
            width: 100%;
            padding: 15px;
            border: none;
            border-radius: 14px;
            background: var(--c);
            color: #fff;
            font-family: 'Outfit',sans-serif;
            font-size: .84rem;
            font-weight: 700;
            letter-spacing: 1.2px;
            text-transform: uppercase;
            cursor: pointer;
            box-shadow: 0 8px 24px var(--cg);
            transition: opacity .2s;
            margin-top: 6px;
        }

            .m-btn:hover {
                opacity: .88
            }

        .m-close {
            float: right;
            background: none;
            border: none;
            font-size: 20px;
            color: var(--text-muted);
            cursor: pointer
        }

        /* ─── BOTONES SIDEBAR ACCIONES ───────────────────────── */
        .sb-actions {
            padding: 0 10px 10px;
            display: flex;
            flex-direction: column;
            gap: 6px
        }

        .sb-action-btn {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 11px 16px;
            border-radius: 12px;
            border: none;
            font-family: 'Inter',sans-serif;
            font-size: .84rem;
            font-weight: 500;
            cursor: pointer;
            transition: all .22s;
            width: 100%;
            text-align: left;
            text-decoration: none;
        }

            .sb-action-btn i {
                font-size: 16px;
                width: 18px;
                text-align: center;
                flex-shrink: 0
            }

            .sb-action-btn.store {
                background: var(--cr);
                color: var(--c);
            }

                .sb-action-btn.store:hover {
                    background: rgba(57,169,0,.18);
                    transform: translateX(3px)
                }

            .sb-action-btn.logout {
                background: rgba(239,68,68,.07);
                color: #dc2626;
            }

                .sb-action-btn.logout:hover {
                    background: rgba(239,68,68,.14);
                    transform: translateX(3px)
                }

        /* Modal confirmación logout */
        .confirm-backdrop {
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,.5);
            backdrop-filter: blur(8px);
            z-index: 300;
            display: none;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

            .confirm-backdrop.open {
                display: flex
            }

        .confirm-card {
            background: var(--panel);
            border-radius: 22px;
            padding: 30px 26px;
            width: 100%;
            max-width: 340px;
            box-shadow: var(--shadow);
            animation: popIn .32s cubic-bezier(.22,1,.36,1) both;
        }

        @@keyframes popIn {
            from {
                opacity: 0;
                transform: scale(.88)
            }

            to {
                opacity: 1;
                transform: scale(1)
            }
        }

        .confirm-ico {
            width: 56px;
            height: 56px;
            border-radius: 18px;
            background: rgba(239,68,68,.1);
            display: grid;
            place-items: center;
            font-size: 24px;
            color: #dc2626;
            margin: 0 auto 16px;
        }

        .confirm-title {
            font-family: 'Outfit',sans-serif;
            font-size: 1.1rem;
            font-weight: 800;
            color: var(--text-primary);
            text-align: center;
            margin-bottom: 8px
        }

        .confirm-desc {
            font-size: .8rem;
            color: var(--text-secondary);
            text-align: center;
            line-height: 1.5;
            margin-bottom: 22px
        }

        .confirm-actions {
            display: flex;
            gap: 10px
        }

        .confirm-cancel {
            flex: 1;
            padding: 13px;
            border: 1.5px solid var(--input-border);
            border-radius: 12px;
            background: transparent;
            color: var(--text-secondary);
            font-family: 'Outfit',sans-serif;
            font-size: .82rem;
            font-weight: 600;
            cursor: pointer;
            transition: all .2s;
        }

            .confirm-cancel:hover {
                background: var(--input-bg)
            }

        .confirm-ok {
            flex: 1;
            padding: 13px;
            border: none;
            border-radius: 12px;
            background: #dc2626;
            color: #fff;
            font-family: 'Outfit',sans-serif;
            font-size: .82rem;
            font-weight: 700;
            cursor: pointer;
            transition: opacity .2s;
            letter-spacing: .5px;
        }

            .confirm-ok:hover {
                opacity: .85
            }

        /* ─── RESPONSIVE ──────────────────────────────────────── */
        @@media (max-width:820px) {
            .sidebar {
                transform: translateX(-100%)
            }

                .sidebar.open {
                    transform: translateX(0)
                }

            .main {
                margin-left: 0;
                padding: 20px 16px
            }

            .bottom-nav {
                display: block
            }

            .widget-grid {
                grid-template-columns: 1fr 1fr
            }
        }

        @@media (max-width:480px) {
            .widget-grid {
                grid-template-columns: 1fr 1fr
            }

            .carnet-fields {
                grid-template-columns: 1fr
            }

            .carnet-inner {
                padding: 18px 16px 16px;
                gap: 14px
            }

            .carnet-photo {
                width: 72px;
                height: 88px
            }

            .carnet-barcode {
                flex-direction: column;
                align-items: flex-start
            }
        }
    </style>
</head>
<!-- ═══ PANEL DE NOTIFICACIONES ════════════════════════ -->
<div class="confirm-backdrop" id="notifBackdrop" onclick="if(event.target===this)closeNotif()">
    <div class="confirm-card" style="max-width:400px;padding:0;overflow:hidden;border-radius:22px">
        <div style="padding:20px 22px 16px;border-bottom:1px solid var(--divider);display:flex;align-items:center;justify-content:space-between">
            <div style="font-family:'Outfit',sans-serif;font-size:1rem;font-weight:800;color:var(--text-primary)">Notificaciones</div>
            <button onclick="closeNotif()" style="background:none;border:none;font-size:20px;color:var(--text-muted);cursor:pointer"><i class="bi bi-x-lg"></i></button>
        </div>
        <div id="notifList"></div>
        <div style="padding:14px 22px;border-top:1px solid var(--divider);text-align:center">
            <a href="#" style="font-size:.75rem;color:var(--c);font-weight:600;text-decoration:none" onclick="closeNotif()">Ver todas las notificaciones</a>
        </div>
    </div>
</div>
<!-- ═══ PANEL DE NOTIFICACIONES ════════════════════════ -->
<div class="confirm-backdrop" id="notifBackdrop" onclick="if(event.target===this)closeNotif()">
    <div class="confirm-card" style="max-width:400px;padding:0;overflow:hidden;border-radius:22px">
        <div style="padding:20px 22px 16px;border-bottom:1px solid var(--divider);display:flex;align-items:center;justify-content:space-between">
            <div style="font-family:'Outfit',sans-serif;font-size:1rem;font-weight:800;color:var(--text-primary)">Notificaciones</div>
            <button onclick="closeNotif()" style="background:none;border:none;font-size:20px;color:var(--text-muted);cursor:pointer"><i class="bi bi-x-lg"></i></button>
        </div>
        <div id="notifList"></div>
        <div style="padding:14px 22px;border-top:1px solid var(--divider);text-align:center">
