                        </div><!-- /sec-recuperar -->
                        <!-- ════════════════════════════════════════════════════════════
                             SECCIÓN 2: REPORTAR ERROR
                             Formulario validado para enviar incidencias al equipo técnico.
                             Genera un número de radicado único al enviarse.
                        ══════════════════════════════════════════════════════════════ -->
                        <div class="section" id="sec-reportar">

                            <!-- Tarjeta de datos del usuario que reporta -->
                            <div class="section-card">
                                <div class="section-card-title">
                                    <i class="bi bi-person-fill"></i>
                                    Tus datos — para identificarte en el reporte
                                </div>

                                <!-- Fila: tipo de documento + número de documento -->
                                <div class="field-row">

                                    <!-- Tipo de documento (CC o TI) -->
                                    <div class="field-group" style="width: 42%">
                                        <label class="field-label">Tipo doc.</label>
                                        <div class="field-wrap">
                                            <i class="bi bi-card-text field-icon"></i>
                                            <select class="form-select" id="rpt-tdoc" name="TipoDocumento">
                                                <option value="CC">CC</option>
                                                <option value="TI">TI</option>
                                                <option value="CE">CE</option>
                                            </select>
                                        </div>
                                    </div>

                                    <!-- Número de documento — solo dígitos, validado -->
                                    <div class="field-group" style="flex: 1">
                                        <label class="field-label">N.º Documento <span style="color:#ef4444">*</span></label>
                                        <div class="field-wrap">
                                            <i class="bi bi-hash field-icon"></i>
                                            <input type="text" class="form-control" id="rpt-doc"
                                                   placeholder="0000000000" maxlength="12"
                                                   onkeypress="return isNumKey(event)"
                                                   oninput="clearError('err-rpt-doc')" />
                                        </div>
                                        <!-- Mensaje de error de validación -->
                                        <div id="err-rpt-doc" class="alert-ui">
                                            <i class="bi bi-exclamation-circle"></i> Ingresa tu número de documento
                                        </div>
                                    </div>
                                </div>

                                <!-- Rol del usuario que reporta -->
                                <div class="field-group">
                                    <label class="field-label">Tu rol <span style="color:#ef4444">*</span></label>
                                    <div class="field-wrap">
                                        <i class="bi bi-person-lines-fill field-icon"></i>
                                        <select class="form-select" id="rpt-rol" onchange="clearError('err-rpt-rol')">
                                            <option value="">— Selecciona tu rol —</option>
                                            <option value="Aprendiz">Aprendiz</option>
                                            <option value="Tienda">Tienda</option>
                                            <option value="Funcionario">Funcionario</option>
                                        </select>
                                    </div>
                                    <div id="err-rpt-rol" class="alert-ui">
                                        <i class="bi bi-exclamation-circle"></i> Selecciona tu rol
                                    </div>
                                </div>

                                <!-- Campo de Ficha — solo aparece si el rol es Aprendiz -->
                                <div class="field-group" id="ficha-group" style="display:none">
                                    <label class="field-label">N.º de Ficha <span style="color:#ef4444">*</span></label>
                                    <div class="field-wrap">
                                        <i class="bi bi-journal-code field-icon"></i>
                                        <input type="text" class="form-control" id="rpt-ficha"
                                               placeholder="Ej. 2895461" maxlength="7"
                                               onkeypress="return isNumKey(event)"
                                               oninput="clearError('err-rpt-ficha')" />
                                    </div>
                                    <div id="err-rpt-ficha" class="alert-ui">
                                        <i class="bi bi-exclamation-circle"></i> Ingresa tu número de ficha
                                    </div>
                                </div>

                            </div><!-- /section-card datos -->
                            <!-- Tarjeta de detalle del error -->
                            <div class="section-card">
                                <div class="section-card-title">
                                    <i class="bi bi-bug-fill"></i>
                                    Descripción del error
                                </div>

                                <!-- Tipo de problema -->
                                <div class="field-group">
                                    <label class="field-label">Tipo de problema <span style="color:#ef4444">*</span></label>
                                    <div class="field-wrap">
                                        <i class="bi bi-exclamation-diamond field-icon"></i>
                                        <select class="form-select" id="rpt-tipo" onchange="clearError('err-rpt-tipo')">
                                            <option value="">— Selecciona el tipo —</option>
                                            <option value="pago">Pago fallido o pendiente</option>
                                            <option value="saldo">Saldo incorrecto</option>
                                            <option value="acceso">No puedo iniciar sesión</option>
                                            <option value="qr">Error al escanear QR</option>
                                            <option value="otro">Otro</option>
                                        </select>
                                    </div>
                                    <div id="err-rpt-tipo" class="alert-ui">
                                        <i class="bi bi-exclamation-circle"></i> Selecciona el tipo de problema
                                    </div>
                                </div>

                                <!-- Descripción detallada -->
                                <div class="field-group">
                                    <label class="field-label">Descripción <span style="color:#ef4444">*</span></label>
                                    <div class="field-wrap">
                                        <textarea class="form-control" id="rpt-desc" name="Descripcion"
                                                  placeholder="Describe qué ocurrió, a qué hora y qué pantalla viste..."
                                                  oninput="clearError('err-rpt-desc')"></textarea>
                                    </div>
                                    <div id="err-rpt-desc" class="alert-ui">
                                        <i class="bi bi-exclamation-circle"></i> Escribe una descripción del error
                                    </div>
                                </div>

                                <!-- Zona de adjuntos (evidencia visual del error) -->
                                <div class="field-group">
                                    <label class="field-label">Evidencia (opcional)</label>
                                    <!-- Al hacer click activa el input file oculto -->
                                    <div class="upload-zone" onclick="document.getElementById('file-input').click()">
                                        <i class="bi bi-cloud-arrow-up-fill"></i>
                                        <p>Haz clic o arrastra tus capturas aquí</p>
                                        <small>PNG, JPG, PDF — máx. 10 MB por archivo</small>
                                    </div>
                                    <!-- Input file oculto — acepta imágenes y PDF -->
                                    <input type="file" id="file-input" multiple
                                           accept="image/*,.pdf" style="display:none"
                                           onchange="handleFileUpload(this)" />
                                    <!-- Contenedor donde se listan los archivos adjuntos -->
                                    <div id="files-preview"></div>
                                </div>

                                <!-- Botón de envío del reporte -->
                                <button class="btn-submit" id="rpt-submit-btn"
                                        onclick="submitReport(event)">
                                    <span id="rpt-btn-text">Enviar reporte</span>
                                    <div class="btn-arrow"><i class="bi bi-send-fill"></i></div>
                                </button>
                            </div>

                            <!-- ── Caja de ticket generado ─────────────────────────── -->
                            <!-- Oculta hasta que el reporte se envíe correctamente -->
                            <div class="ticket-box" id="ticket-result">
                                <div class="section-card-title" style="margin-bottom:8px;">
                                    <i class="bi bi-ticket-fill"></i> Reporte recibido — Número de radicado
                                </div>
                                <!-- El número se genera dinámicamente en JS -->
                                <span class="ticket-num" id="ticket-num">SP-2025-00000</span>
                                <!-- Metadata del reporte: fecha, tipo, tiempo de respuesta -->
                                <div class="ticket-meta" id="ticket-meta"></div>
                                <!-- Acciones: copiar el número o "descargar" comprobante -->
                                <div class="ticket-actions">
                                    <button class="btn-sm" onclick="copyTicketNum()">
                                        <i class="bi bi-clipboard"></i> Copiar N.º
                                    </button>
                                    <button class="btn-sm">
                                        <i class="bi bi-download"></i> Comprobante
                                    </button>
                                </div>
                            </div>

                        </div><!-- /sec-reportar -->
                        <!-- ════════════════════════════════════════════════════════════
                             SECCIÓN 3: BLOQUEAR DOCUMENTO (EMERGENCIA)
                             Flujo de emergencia de tres pasos:
                             1. El usuario confirma su documento y motivo
                             2. Escribe la palabra "BLOQUEAR" para confirmar
                             3. La cuenta queda suspendida y se genera un radicado
                        ══════════════════════════════════════════════════════════════ -->
                        <div class="section" id="sec-bloquear">

                            <!-- Banner de advertencia rojo -->
                            <div class="emergency-banner">
                                <strong>
                                    <i class="bi bi-exclamation-octagon-fill"></i>
                                    Acción de emergencia — Efectiva de inmediato
                                </strong>
                                <p>
                                    Bloquear tu documento <strong>suspende todos los pagos</strong>
                                    asociados a tu cuenta de forma instantánea. Úsalo solo si
                                    perdiste tu carnet, te robaron el acceso o detectaste movimientos
                                    no autorizados. Para desbloquear deberás presentarte personalmente
                                    en el centro.
                                </p>
                            </div>

                            <!-- ── Paso 1: Formulario de verificación ─────────────── -->
                            <!-- Se oculta cuando el usuario pasa al paso de confirmación -->
                            <div class="section-card" id="blk-form-step">
                                <div class="section-card-title">
                                    <i class="bi bi-shield-check"></i>
                                    Paso 1 — Verificar identidad
                                </div>

                                <!-- Tipo + número de documento del titular de la cuenta -->
                                <div class="field-row">
                                    <div class="field-group" style="width: 42%">
                                        <label class="field-label">Tipo doc.</label>
                                        <div class="field-wrap">
                                            <i class="bi bi-card-text field-icon"></i>
                                            <select class="form-select" id="blk-tdoc">
                                                <option value="CC">CC</option>
                                                <option value="TI">TI</option>
                                            </select>
                                        </div>
                                    </div>
                                    <div class="field-group" style="flex: 1">
                                        <label class="field-label">N.º Documento <span style="color:#ef4444">*</span></label>
                                        <div class="field-wrap">
                                            <i class="bi bi-hash field-icon"></i>
                                            <input type="text" class="form-control" id="blk-doc"
                                                   placeholder="Documento del titular" maxlength="12"
                                                   onkeypress="return isNumKey(event)"
                                                   oninput="clearError('err-blk-doc')" />
                                        </div>
                                        <div id="err-blk-doc" class="alert-ui">
                                            <i class="bi bi-exclamation-circle"></i> Ingresa el documento del titular
                                        </div>
                                    </div>
                                </div>

                                <!-- Motivo del bloqueo -->
                                <div class="field-group">
                                    <label class="field-label">Motivo del bloqueo <span style="color:#ef4444">*</span></label>
                                    <div class="field-wrap">
                                        <i class="bi bi-question-circle-fill field-icon"></i>
                                        <select class="form-select" id="blk-motivo" onchange="clearError('err-blk-motivo')">
                                            <option value="">— Selecciona el motivo —</option>
                                            <option value="carnet">Pérdida de carnet SENA</option>
                                            <option value="robo">Robo o hurto</option>
                                            <option value="acceso">Acceso no autorizado sospechoso</option>
                                            <option value="dispositivo">Pérdida de dispositivo con sesión activa</option>
                                        </select>
                                    </div>
                                    <div id="err-blk-motivo" class="alert-ui">
                                        <i class="bi bi-exclamation-circle"></i> Selecciona el motivo del bloqueo
                                    </div>
                                </div>

                                <!-- Botón para continuar al paso de confirmación -->
                                <button class="btn-submit danger" onclick="goToConfirmStep()">
                                    <span>Continuar</span>
                                    <div class="btn-arrow"><i class="bi bi-arrow-right"></i></div>
                                </button>

                            </div><!-- /blk-form-step -->
                            <!-- ── Paso 2: Confirmación por escritura ─────────────── -->
                            <!-- Oculto hasta que el usuario pase el paso 1 -->
                            <div class="confirm-block" id="blk-confirm-step">
                                <div class="section-card">
                                    <div class="section-card-title" style="color:#dc2626;">
                                        <i class="bi bi-keyboard"></i>
                                        Paso 2 — Confirmación de escritura
                                    </div>

                                    <!-- Instrucción para escribir la palabra clave -->
                                    <div class="confirm-hint">
                                        Para confirmar el bloqueo escribe la palabra
                                        <strong>BLOQUEAR</strong> exactamente como aparece (en mayúsculas):
                                    </div>

                                    <!-- Campo de confirmación — se valida en tiempo real -->
                                    <div class="field-group">
                                        <label class="field-label">Escribe: BLOQUEAR</label>
                                        <div class="field-wrap">
                                            <i class="bi bi-pencil-fill field-icon"></i>
                                            <input type="text" class="form-control" id="blk-confirm-text"
                                                   placeholder='Escribe "BLOQUEAR"'
                                                   oninput="checkConfirmWord()"
                                                   autocomplete="off" />
                                        </div>
                                    </div>

                                    <!-- Botón de bloqueo definitivo — deshabilitado hasta que el texto coincida -->
                                    <button class="btn-submit danger" id="blk-final-btn"
                                            disabled onclick="executeBlock(event)">
                                        <span id="blk-final-text">Bloquear cuenta ahora</span>
                                        <div class="btn-arrow"><i class="bi bi-shield-x"></i></div>
                                    </button>

                                    <!-- Enlace para cancelar y volver al formulario -->
                                    <div style="text-align:center; margin-top:12px;">
                                        <a href="#" style="font-size:.72rem; color:#94a3b8; text-decoration:none;"
                                           onclick="cancelBlock(event)">
                                            Cancelar — volver al formulario
                                        </a>
                                    </div>
                                </div>
                            </div><!-- /blk-confirm-step -->
                            <!-- ── Pantalla de éxito tras el bloqueo ─────────────── -->
                            <!-- Oculta hasta que se complete el bloqueo -->
                            <div class="block-success" id="blk-success">
                                <!-- Ícono de candado con animación de rebote -->
                                <i class="bi bi-lock-fill block-success-icon"></i>
                                <h3>Cuenta bloqueada exitosamente</h3>
                                <p>
                                    Tu cuenta ha sido suspendida. Ningún pago podrá realizarse
                                    con este documento hasta que te presentes en el centro con tu
                                    identificación original.<br><br>
                                    <strong>Radicado de emergencia: </strong>
                                    <span id="blk-radicado" style="font-family:'Outfit',sans-serif; font-weight:800; color:#ef4444;"></span>
                                </p>
                                <!-- Botón para reportar también en el área de reportes -->
                                <button class="btn-sm" style="margin-top:14px;"
                                        onclick="showSection('reportar', document.getElementById('tab-reportar'))">
                                    <i class="bi bi-flag-fill"></i> Hacer un reporte adicional
                                </button>
                            </div><!-- /blk-success -->

                        </div><!-- /sec-bloquear -->
                        <!-- ── Footer de la tarjeta ────────────────────────────── -->
                        <div class="card-footer">
                            <div class="footer-links">
                                <a asp-controller="Home" asp-action="Index">Volver al inicio de sesión</a>
                                <a href="#">Términos y condiciones</a>
                            </div>
                            <div style="display:flex; justify-content:space-between; align-items:center;">
                                <div style="font-size:.72rem; color:#cbd5e1">By <strong>CTA S.S.C</strong></div>
                                <!-- Badge de seguridad SSL -->
                                <div style="display:flex; align-items:center; gap:5px; font-size:.68rem; color:#94a3b8">
                                    <div style="width:6px; height:6px; border-radius:50%; background:#22c55e;"></div>
                                    SSL Seguro
                                </div>
                            </div>
                        </div>

                    </div><!-- /card -->
                </div><!-- /card-tilt -->
            </div><!-- /scroll-area -->
        </div><!-- /l-panel -->
        <!-- ════════════════════════════════════════════════════════════════════
