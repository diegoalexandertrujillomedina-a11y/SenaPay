    </div><!-- /shell -->
    <!-- ══════════════════════════════════════════════════════════════════════════
         JAVASCRIPT
         Toda la lógica interactiva de la página, comentada función por función.
    ════════════════════════════════════════════════════════════════════════════ -->
    <script>

        /* ══════════════════════════════════════════════════════════════════════
           CONFIGURACIÓN DE ROLES (tabla de temas)
           Cada rol tiene: color primario (c), componentes RGB (r,g,b),
           glow semitransparente (cg), halo de foco (cr), icono Bootstrap Icons
           y la palabra de énfasis del panel derecho.
           Esta tabla es la misma del Login, extendida para el soporte.
        ══════════════════════════════════════════════════════════════════════ */
        const ROLES = {
          Aprendiz:   { c:'#39A900', r:57,  g:169, b:0,   cg:'rgba(57,169,0,.18)',   cr:'rgba(57,169,0,.07)',   icon:'bi-person-badge-fill', word:'confiable' },
          Tienda:     { c:'#E86C00', r:232, g:108, b:0,   cg:'rgba(232,108,0,.2)',   cr:'rgba(232,108,0,.07)',  icon:'bi-shop',              word:'seguro'    },
          Funcionario:{ c:'#6D28D9', r:109, g:40,  b:217, cg:'rgba(109,40,217,.2)', cr:'rgba(109,40,217,.07)', icon:'bi-briefcase-fill',    word:'avanzado'  }
        };

        /* ── Estado global ──────────────────────────────────────────────── */
        let currentRole = 'Aprendiz'; // Rol activo en el selector de recuperación
        let tiltX = 0, tiltY = 0;    // Inclinación actual de la tarjeta (interpolada)
        let targetX = 0, targetY = 0; // Inclinación objetivo (desde el mousemove)

        /* ══════════════════════════════════════════════════════════════════════
           isNumKey(event)
           Filtra el evento keypress para permitir solo dígitos (0-9).
           Se usa en los campos de documento y ficha para evitar letras.
           @@param {KeyboardEvent} e  — evento de teclado
           @@returns {boolean}        — true si es un dígito, false en caso contrario
        ══════════════════════════════════════════════════════════════════════ */
        function isNumKey(e) {
          const code = e.which || e.keyCode;
          return (code >= 48 && code <= 57); // 48='0', 57='9'
        }

        /* ══════════════════════════════════════════════════════════════════════
           showSection(sectionId, tabElement)
           Navega entre las tres secciones principales (recuperar / reportar / bloquear).
           Oculta todas las secciones, desactiva todos los tabs, luego activa
           la sección y el tab correspondientes y reposiciona el glider.
           @@param {string}      sectionId  — ID de la sección a mostrar (sin prefijo "sec-")
           @@param {HTMLElement} tabElement — Elemento <button> del tab clicado
        ══════════════════════════════════════════════════════════════════════ */
        function showSection(sectionId, tabElement) {
          // 1. Ocultar todas las secciones
          document.querySelectorAll('.section').forEach(s => s.classList.remove('active'));

          // 2. Desactivar todos los tabs
          document.querySelectorAll('.role-tab').forEach(t => t.classList.remove('active'));

          // 3. Activar la sección solicitada
          document.getElementById('sec-' + sectionId).classList.add('active');

          // 4. Activar el tab correspondiente
          tabElement.classList.add('active');

          // 5. Mover el glider al tab activo
          moveGlider(tabElement, 'mainGlider', 'mainTabs');

          // 6. Scroll al inicio del área de contenido
          document.querySelector('.scroll-area').scrollTop = 0;
        }

        /* ══════════════════════════════════════════════════════════════════════
           moveGlider(tabEl, gliderId, tabsId)
           Calcula la posición y el ancho del tab activo dentro de su contenedor
           y anima el indicador deslizante (tab-glider) hacia esa posición.
           @@param {HTMLElement} tabEl    — Tab activo
           @@param {string}      gliderId — ID del elemento .tab-glider
           @@param {string}      tabsId   — ID del contenedor .role-tabs
        ══════════════════════════════════════════════════════════════════════ */
        function moveGlider(tabEl, gliderId, tabsId) {
          const glider    = document.getElementById(gliderId);
          const tabsRect  = document.getElementById(tabsId).getBoundingClientRect();
          const tabRect   = tabEl.getBoundingClientRect();

          // Posición relativa al contenedor menos el padding izquierdo (6px → aquí 5)
          glider.style.left  = (tabRect.left - tabsRect.left - 5) + 'px';
          glider.style.width = tabRect.width + 'px';
          // La transición CSS cubic-bezier produce el efecto elástico automáticamente
        }

        /* ══════════════════════════════════════════════════════════════════════
           selectRecoveryRole(roleName, cardElement)
           Cambia el rol seleccionado en la sección "Recuperar acceso".
           1. Actualiza la variable CSS --c y sus derivadas al color del rol.
           2. Actualiza el ícono de la marca y la palabra del panel derecho.
           3. Activa visualmente la tarjeta de rol clickeada.
           4. Muestra el bloque de pasos correspondiente al rol.
           @@param {string}      roleName    — 'Aprendiz' | 'Tienda' | 'Funcionario'
           @@param {HTMLElement} cardElement — Tarjeta .role-card clickeada
        ══════════════════════════════════════════════════════════════════════ */
        function selectRecoveryRole(roleName, cardElement) {
          currentRole = roleName;
          const theme = ROLES[roleName];

          // 1. Actualizar las variables CSS de color en el documento
          document.documentElement.style.setProperty('--c',  theme.c);
          document.documentElement.style.setProperty('--cg', theme.cg);
          document.documentElement.style.setProperty('--cr', theme.cr);

          // 2. Actualizar ícono de la marca y palabra del panel derecho
          document.getElementById('brandIco').className  = 'bi ' + theme.icon;
          document.getElementById('heroWord').textContent = theme.word;

          // 3. Activar la tarjeta clickeada (desactiva las otras)
          document.querySelectorAll('.role-card').forEach(c => c.classList.remove('active'));
          cardElement.classList.add('active');

          // 4. Mostrar el bloque de pasos del rol seleccionado
          document.querySelectorAll('.steps-container').forEach(s => s.classList.remove('active'));
          document.getElementById('steps-' + roleName).classList.add('active');
        }

        /* ══════════════════════════════════════════════════════════════════════
           clearError(errorId)
           Oculta el mensaje de error de validación de un campo específico.
           Se llama en el evento oninput de cada campo para limpiar errores al escribir.
           @@param {string} errorId — ID del div .alert-ui a ocultar
        ══════════════════════════════════════════════════════════════════════ */
        function clearError(errorId) {
          document.getElementById(errorId).style.display = 'none';
        }

        /* ══════════════════════════════════════════════════════════════════════
           showError(errorId)
           Muestra el mensaje de error de un campo y hace scroll suave hacia él.
           @@param {string} errorId — ID del div .alert-ui a mostrar
        ══════════════════════════════════════════════════════════════════════ */
        function showError(errorId) {
          const el = document.getElementById(errorId);
          el.style.display = 'flex';
          el.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        }

        /* ══════════════════════════════════════════════════════════════════════
           Listener: cambio en el selector de rol del reporte
           Muestra u oculta el campo "N.º de Ficha" según si el rol es Aprendiz.
        ══════════════════════════════════════════════════════════════════════ */
        document.getElementById('rpt-rol').addEventListener('change', function() {
          // El campo de ficha solo es requerido para Aprendices
          const fichaGroup = document.getElementById('ficha-group');
          fichaGroup.style.display = (this.value === 'Aprendiz') ? 'block' : 'none';
          clearError('err-rpt-rol');
        });

        /* ══════════════════════════════════════════════════════════════════════
           handleFileUpload(inputEl)
           Procesa los archivos seleccionados en la zona de carga y los lista
           visualmente con un botón de eliminación por archivo.
           @@param {HTMLInputElement} inputEl — Input type="file"
        ══════════════════════════════════════════════════════════════════════ */
        function handleFileUpload(inputEl) {
          const container = document.getElementById('files-preview');

          // Iterar sobre cada archivo seleccionado
          Array.from(inputEl.files).forEach(file => {
            // Crear el ítem visual del archivo
            const item = document.createElement('div');
            item.className = 'file-item';
            item.innerHTML =
              `<span><i class="bi bi-file-earmark-image-fill"></i>${file.name}</span>` +
              `<button class="file-remove" onclick="this.parentElement.remove()"
                       title="Eliminar archivo">&times;</button>`;
            container.appendChild(item);
          });

          // Limpiar el input para permitir seleccionar el mismo archivo de nuevo
          inputEl.value = '';
        }

        /* ══════════════════════════════════════════════════════════════════════
           submitReport(event)
           Valida el formulario de reporte campo por campo y, si todo es válido:
           1. Deshabilita el botón y muestra estado de carga.
           2. Genera un número de radicado único.
           3. Muestra la caja .ticket-box con los datos del ticket.
           @@param {MouseEvent} event — Evento click del botón
        ══════════════════════════════════════════════════════════════════════ */
        function submitReport(event) {
          // ── Efecto ripple en el botón ──────────────────────────────────
          btnRipple(event);

          /* ── Recolectar valores de los campos ── */
          const doc  = document.getElementById('rpt-doc').value.trim();
          const rol  = document.getElementById('rpt-rol').value;
          const tipo = document.getElementById('rpt-tipo').value;
          const desc = document.getElementById('rpt-desc').value.trim();
          const ficha = document.getElementById('rpt-ficha').value.trim();

          /* ── Validación campo a campo ── */
          let isValid = true;

          // Validar documento (mínimo 6 dígitos)
          if (!doc || doc.length < 6) {
            showError('err-rpt-doc'); isValid = false;
          }

          // Validar rol seleccionado
          if (!rol) {
            showError('err-rpt-rol'); isValid = false;
          }

          // Si es Aprendiz, validar ficha (7 dígitos)
          if (rol === 'Aprendiz' && (!ficha || ficha.length < 6)) {
            showError('err-rpt-ficha'); isValid = false;
          }

          // Validar tipo de problema
          if (!tipo) {
            showError('err-rpt-tipo'); isValid = false;
          }

          // Validar descripción (mínimo 10 caracteres)
          if (desc.length < 10) {
            showError('err-rpt-desc'); isValid = false;
          }

          // Si hay algún error, detener el envío
          if (!isValid) return;

          /* ── Simular envío: estado de carga ── */
          const btn     = document.getElementById('rpt-submit-btn');
          const btnText = document.getElementById('rpt-btn-text');
          btn.disabled      = true;
          btnText.textContent = 'Enviando...';

          // Simular latencia de red (reemplazar por fetch real en producción)
          setTimeout(() => {
            /* ── Generar número de radicado único ── */
            // Formato: SP-[año]-[número aleatorio de 5 dígitos]
            const year     = new Date().getFullYear();
            const randNum  = Math.floor(Math.random() * 90000) + 10000;
            const radicado = `SP-${year}-${randNum}`;

            // Obtener fecha y hora actuales formateadas
            const now  = new Date();
            const fecha = now.toLocaleDateString('es-CO', {
              year:'numeric', month:'long', day:'numeric'
            });
            const hora = now.toLocaleTimeString('es-CO', {
              hour:'2-digit', minute:'2-digit'
            });

            // Mapear el valor del tipo a texto legible
            const tiposMap = {
              pago:'Pago fallido o pendiente', saldo:'Saldo incorrecto',
              acceso:'No puede iniciar sesión', qr:'Error al escanear QR', otro:'Otro'
            };

            /* ── Llenar y mostrar la caja del ticket ── */
            document.getElementById('ticket-num').textContent  = radicado;
            document.getElementById('ticket-meta').innerHTML   =
              `Enviado el <strong>${fecha}</strong> a las <strong>${hora}</strong><br>` +
              `Tipo: ${tiposMap[tipo] || tipo} · Rol: ${rol}<br>` +
              `Tiempo estimado de respuesta: <strong>24–48 horas hábiles</strong>`;

            const ticketBox = document.getElementById('ticket-result');
            ticketBox.classList.add('show');
            ticketBox.scrollIntoView({ behavior: 'smooth', block: 'nearest' });

            // Restaurar botón para nuevos reportes
            btn.disabled        = false;
            btnText.textContent = 'Enviar otro reporte';
          }, 1200); // 1.2 segundos de simulación de red
        }

        /* ══════════════════════════════════════════════════════════════════════
           copyTicketNum()
           Copia el número de radicado generado al portapapeles del usuario.
           Muestra una indicación visual temporal en el botón.
        ══════════════════════════════════════════════════════════════════════ */
        function copyTicketNum() {
          const num = document.getElementById('ticket-num').textContent;
          navigator.clipboard.writeText(num).then(() => {
            // Feedback visual: cambiar texto del botón momentáneamente
            const btn = event.currentTarget;
            btn.innerHTML = '<i class="bi bi-check-lg"></i> ¡Copiado!';
            setTimeout(() => {
              btn.innerHTML = '<i class="bi bi-clipboard"></i> Copiar N.º';
            }, 2000);
          });
        }

        /* ══════════════════════════════════════════════════════════════════════
           goToConfirmStep()
           Valida el formulario del paso 1 de bloqueo (documento y motivo).
           Si es válido, oculta el formulario y muestra el paso de confirmación.
        ══════════════════════════════════════════════════════════════════════ */
        function goToConfirmStep() {
          const doc    = document.getElementById('blk-doc').value.trim();
          const motivo = document.getElementById('blk-motivo').value;

          let isValid = true;

          if (!doc || doc.length < 6) {
            showError('err-blk-doc'); isValid = false;
          }
          if (!motivo) {
            showError('err-blk-motivo'); isValid = false;
          }

          if (!isValid) return;

          // Ocultar el formulario del paso 1
          document.getElementById('blk-form-step').style.display = 'none';

          // Mostrar el bloque de confirmación del paso 2
          const confirmStep = document.getElementById('blk-confirm-step');
          confirmStep.classList.add('show');
          confirmStep.scrollIntoView({ behavior: 'smooth', block: 'start' });

          // Limpiar el campo de confirmación por si el usuario regresó
          document.getElementById('blk-confirm-text').value = '';
          document.getElementById('blk-final-btn').disabled = true;
        }

        /* ══════════════════════════════════════════════════════════════════════
           cancelBlock(event)
           Cancela el flujo de bloqueo y regresa al paso 1 del formulario.
           @@param {MouseEvent} event — Evento click del enlace "Cancelar"
        ══════════════════════════════════════════════════════════════════════ */
        function cancelBlock(event) {
          event.preventDefault();

          // Mostrar de nuevo el formulario del paso 1
          document.getElementById('blk-form-step').style.display = 'block';

          // Ocultar el bloque de confirmación
          document.getElementById('blk-confirm-step').classList.remove('show');
        }

        /* ══════════════════════════════════════════════════════════════════════
           checkConfirmWord()
           Se ejecuta en cada pulsación de tecla en el campo de confirmación.
           Compara el valor con 'BLOQUEAR' y habilita/deshabilita el botón final.
        ══════════════════════════════════════════════════════════════════════ */
        function checkConfirmWord() {
          const text   = document.getElementById('blk-confirm-text').value;
          const finalBtn = document.getElementById('blk-final-btn');

          // Solo habilitar si la palabra es exactamente "BLOQUEAR"
          finalBtn.disabled = (text !== 'BLOQUEAR');
        }

        /* ══════════════════════════════════════════════════════════════════════
           executeBlock(event)
           Ejecuta el bloqueo definitivo de la cuenta:
           1. Aplica el efecto ripple al botón.
           2. Simula la petición al servidor.
           3. Oculta el bloque de confirmación y muestra la pantalla de éxito.
           4. Genera el radicado de emergencia.
           @@param {MouseEvent} event — Evento click del botón de bloqueo
        ══════════════════════════════════════════════════════════════════════ */
        function executeBlock(event) {
          btnRipple(event);

          // Estado de carga del botón
          const btn = document.getElementById('blk-final-btn');
          btn.disabled = true;
          document.getElementById('blk-final-text').textContent = 'Procesando bloqueo...';

          // Simular petición al servidor (reemplazar por fetch real)
          setTimeout(() => {
            // Generar radicado de emergencia con prefijo EMG
            const randNum  = Math.floor(Math.random() * 90000) + 10000;
            const radicado = `EMG-${new Date().getFullYear()}-${randNum}`;

            // Mostrar el radicado en la pantalla de éxito
            document.getElementById('blk-radicado').textContent = radicado;

            // Ocultar el bloque de confirmación
            document.getElementById('blk-confirm-step').classList.remove('show');

            // Mostrar la pantalla de éxito con animación
            document.getElementById('blk-success').classList.add('show');
            document.getElementById('blk-success').scrollIntoView({ behavior:'smooth', block:'start' });
          }, 1400);
        }

        /* ══════════════════════════════════════════════════════════════════════
           btnRipple(event)
           Crea un elemento <span> que se expande desde el punto de click
           dentro del botón y se desvanece, simulando el efecto Material ripple.
           @@param {MouseEvent} event — Evento click con coordenadas
        ══════════════════════════════════════════════════════════════════════ */
        function btnRipple(event) {
          const btn  = event.currentTarget;
          const rect = btn.getBoundingClientRect();

          // Crear el elemento del ripple
          const ripple = document.createElement('span');
          ripple.style.cssText =
            `position:absolute; background:rgba(255,255,255,.3); border-radius:50%;` +
            `width:100px; height:100px;` +
            `left:${event.clientX - rect.left - 50}px;` +
            `top:${event.clientY - rect.top  - 50}px;` +
            `transform:scale(0); animation:rip .6s ease-out;` +
            `pointer-events:none;`;

          btn.appendChild(ripple);

          // Eliminar el elemento tras la animación para no acumular DOM
          setTimeout(() => ripple.remove(), 600);
        }

        /* ══════════════════════════════════════════════════════════════════════
           lerp(a, b, t)
           Interpolación lineal entre dos valores: a + (b - a) * t
           Usada en el efecto tilt para suavizar el movimiento de la tarjeta.
           @@param {number} a — Valor inicial
           @@param {number} b — Valor objetivo
           @@param {number} t — Factor de interpolación [0..1] (velocidad)
           @@returns {number}
        ══════════════════════════════════════════════════════════════════════ */
        function lerp(a, b, t) { return a + (b - a) * t; }

        /* ══════════════════════════════════════════════════════════════════════
           EFECTO TILT 3D
           Escucha el movimiento del ratón sobre el panel izquierdo y calcula
           los ángulos de inclinación objetivo. El loop de animación interpola
           suavemente la transformación de la tarjeta cada frame.
        ══════════════════════════════════════════════════════════════════════ */
        const tiltWrap = document.getElementById('tiltWrap');

        // Cuando el ratón se mueve dentro del panel: calcular ángulos objetivo
        document.getElementById('lPanel').addEventListener('mousemove', e => {
          const rect = tiltWrap.getBoundingClientRect();
          // targetX: inclinación vertical (rotateX) — invertido para efecto natural
          targetX = (e.clientY - rect.top  - rect.height / 2) / rect.height * -9;
          // targetY: inclinación horizontal (rotateY)
          targetY = (e.clientX - rect.left - rect.width  / 2) / rect.width  *  9;
        });

        // Cuando el ratón sale: volver al centro suavemente
        document.getElementById('lPanel').addEventListener('mouseleave', () => {
          targetX = 0; targetY = 0;
        });

        // Loop de animación: cada frame interpola la inclinación actual hacia el objetivo
        (function animateTilt() {
          tiltX = lerp(tiltX, targetX, .08); // .08 = velocidad de interpolación
          tiltY = lerp(tiltY, targetY, .08);
          tiltWrap.style.transform =
            `perspective(900px) rotateX(${tiltX.toFixed(2)}deg) rotateY(${tiltY.toFixed(2)}deg)`;
          requestAnimationFrame(animateTilt); // solicitar el siguiente frame
        })();

        /* ══════════════════════════════════════════════════════════════════════
           FONDO GEOMÉTRICO SVG (panel derecho)
           Dibuja polígonos, círculos y líneas aleatorios en el canvas SVG
           usando el color primario del rol activo.
           Se vuelve a dibujar al redimensionar la ventana.
        ══════════════════════════════════════════════════════════════════════ */
        const NS  = 'http://www.w3.org/2000/svg';   // Namespace SVG estándar
        const cvs = document.getElementById('geo-canvas'); // Canvas SVG destino

        /* rand(min, max) — Número aleatorio entre min y max */
        function rand(min, max) { return Math.random() * (max - min) + min; }

        function drawGeo() {
          cvs.innerHTML = ''; // Limpiar el canvas antes de redibujar

          const W = document.getElementById('rPanel').clientWidth;
          const H = document.getElementById('rPanel').clientHeight;

          // Detectar si está en modo oscuro para ajustar opacidades
          const dark      = window.matchMedia('(prefers-color-scheme: dark)').matches;
          const theme     = ROLES[currentRole];
          const baseAlpha = dark ? 0.05 : 0.08; // Opacidad base de las figuras

          /* ── Dibujar polígonos irregulares de fondo ── */
          for (let i = 0; i < 8; i++) {
            const pts = Array.from({length: 5}, () =>
              `${rand(0, W).toFixed(0)},${rand(0, H).toFixed(0)}`
            ).join(' ');

            const poly = document.createElementNS(NS, 'polygon');
            poly.setAttribute('points', pts);
            poly.setAttribute('fill',   `rgba(${theme.r},${theme.g},${theme.b},${rand(baseAlpha * .3, baseAlpha)})`);
            poly.setAttribute('stroke', `rgba(${theme.r},${theme.g},${theme.b},${baseAlpha * 1.5})`);
            poly.setAttribute('stroke-width', '0.5');
            cvs.appendChild(poly);
          }

          /* ── Dibujar círculos semitransparentes ── */
          for (let i = 0; i < 12; i++) {
            const circle = document.createElementNS(NS, 'circle');
            circle.setAttribute('cx', rand(0, W).toFixed(0));
            circle.setAttribute('cy', rand(0, H).toFixed(0));
            circle.setAttribute('r',  rand(20, 120).toFixed(0));
            circle.setAttribute('fill',   `rgba(${theme.r},${theme.g},${theme.b},${rand(baseAlpha * .2, baseAlpha * .6)})`);
            circle.setAttribute('stroke', `rgba(${theme.r},${theme.g},${theme.b},${baseAlpha})`);
            circle.setAttribute('stroke-width', rand(0.5, 2).toFixed(1));
            cvs.appendChild(circle);
          }

          /* ── Dibujar líneas de conexión ── */
          for (let i = 0; i < 10; i++) {
            const line = document.createElementNS(NS, 'line');
            line.setAttribute('x1', rand(0, W).toFixed(0));
            line.setAttribute('y1', rand(0, H).toFixed(0));
            line.setAttribute('x2', rand(0, W).toFixed(0));
            line.setAttribute('y2', rand(0, H).toFixed(0));
            line.setAttribute('stroke',       `rgba(${theme.r},${theme.g},${theme.b},${rand(0.04, 0.1)})`);
            line.setAttribute('stroke-width', rand(0.5, 1.5).toFixed(1));
            cvs.appendChild(line);
          }
        }

        // Dibujar al cargar la página
        drawGeo();

        // Redibujar si cambia el tamaño de la ventana (responsive)
        window.addEventListener('resize', drawGeo);

        // Redibujar si cambia la preferencia de modo oscuro/claro
        window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', drawGeo);

        /* ══════════════════════════════════════════════════════════════════════
           INICIALIZACIÓN AL CARGAR
           Una vez que el DOM está completo, posicionar el glider en el tab activo.
        ══════════════════════════════════════════════════════════════════════ */
        window.addEventListener('load', () => {
          // Posicionar el glider sobre la primera pestaña (Recuperar) al iniciar
          moveGlider(
            document.querySelector('.role-tab.active'),
            'mainGlider',
            'mainTabs'
          );
        });

    </script>

    <!-- Keyframes del efecto ripple del botón (definidos aquí para compatibilidad) -->
    <style>
        @@keyframes rip {
            to {
                transform: scale(2.5);
                opacity: 0;
            }
        }
    </style>

</body>
</html>