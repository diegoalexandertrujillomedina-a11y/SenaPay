@model RecuperarPasswordViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>SenaPay | Recuperar Contraseña</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@500;700;800&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0
        }

        :root {
            --c: #39A900;
            --cg: rgba(57,169,0,.18);
            --cr: rgba(57,169,0,.07);
            --speed: .55s
        }

        @@media (prefers-color-scheme: dark) {
            body {
                background: #060608;
            }

            .l-panel {
                background: #111114 !important;
                border-color: #222 !important;
            }

            .card {
                background: #1a1a1e !important;
                border-color: rgba(255,255,255,.05) !important;
                color: #fff;
            }

            .brand-text h1 {
                color: #fff !important;
            }

            .r-text h2 {
                color: #fff !important;
            }

            .form-control, .form-select {
                background: #252529 !important;
                border-color: #333 !important;
                color: #eee !important;
            }

            .field-label {
                color: #64748b;
            }

            .card-footer {
                border-top-color: #252529;
            }

            .r-panel {
                background: #060608 !important;
            }

            .r-text p {
                color: rgba(255,255,255,.7);
            }

            .r-pill {
                color: rgba(255,255,255,.8) !important;
                background: rgba(255,255,255,.06) !important;
                border-color: rgba(255,255,255,.1) !important;
            }

            .r-overlay {
                background: radial-gradient(ellipse 65% 55% at 65% 35%,transparent,rgba(4,4,6,.6) 80%), linear-gradient(180deg,transparent 45%,rgba(4,4,6,.92)) !important;
            }

            .back-link {
                color: rgba(255,255,255,.45) !important;
            }

                .back-link:hover {
                    color: var(--c) !important;
                }
        }

        body, html {
            height: 100%;
            overflow: hidden;
            font-family: 'Inter', sans-serif;
            background: #060608;
            -webkit-font-smoothing: antialiased
        }

        .shell {
            display: flex;
            height: 100vh
        }

        .l-panel {
            width: 42%;
            min-width: 420px;
            background: #fff;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            z-index: 20;
            padding: 40px 28px;
            overflow: hidden
        }

            .l-panel::after {
                content: '';
                position: absolute;
                right: -1px;
                top: 0;
                bottom: 0;
                width: 1px;
                background: linear-gradient(180deg,transparent,rgba(0,0,0,.07) 40%,rgba(0,0,0,.07) 60%,transparent)
            }

        .card-tilt {
            width: 100%;
            max-width: 400px;
            position: relative;
            z-index: 1;
            transform-style: preserve-3d;
            perspective: 900px;
            animation: slideUp .7s cubic-bezier(.22,1,.36,1) both
        }

        @@keyframes slideUp {
            from {
                opacity: 0;
                transform: translateY(32px)
            }

            to {
                opacity: 1;
                transform: translateY(0)
            }
        }

        .card {
            background: #fff;
            border-radius: 24px;
            padding: 36px 32px;
            box-shadow: 0 4px 24px rgba(0,0,0,.06), 0 1px 3px rgba(0,0,0,.04);
            border: 1px solid rgba(0,0,0,.045);
            transform-style: preserve-3d;
            will-change: transform
        }

        .brand-row {
            display: flex;
            align-items: center;
            gap: 14px;
            margin-bottom: 28px
        }

        .brand-icon {
            width: 52px;
            height: 52px;
            border-radius: 16px;
            background: var(--c);
            display: grid;
            place-items: center;
            color: #fff;
            font-size: 22px;
            flex-shrink: 0;
            box-shadow: 0 8px 24px var(--cg);
            transition: background var(--speed), box-shadow var(--speed)
        }

        .brand-text h1 {
            font-family: 'Outfit', sans-serif;
            font-size: 1.75rem;
            font-weight: 800;
            color: #0f0f0f;
            line-height: 1;
            letter-spacing: -.5px
        }

        .brand-text span {
            font-size: .72rem;
            color: #94a3b8;
            letter-spacing: .5px;
            display: block;
            margin-top: 3px
        }

        .section-title {
            font-family: 'Outfit', sans-serif;
            font-size: .82rem;
            font-weight: 700;
            color: #64748b;
            text-transform: uppercase;
            letter-spacing: 1.4px;
            margin-bottom: 18px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

            .section-title::after {
                content: '';
                flex: 1;
                height: 1px;
                background: #f1f5f9;
            }

        .field-group {
            margin-bottom: 16px
        }

        .field-label {
            display: block;
            font-family: 'Outfit', sans-serif;
            font-size: .68rem;
            font-weight: 600;
            color: #94a3b8;
            text-transform: uppercase;
            letter-spacing: 1.2px;
            margin-bottom: 6px
        }

        .field-wrap {
            position: relative
        }

        .field-icon {
            position: absolute;
            left: 13px;
            top: 50%;
            transform: translateY(-50%);
            color: #c8d3dc;
            font-size: 14px;
            pointer-events: none;
            transition: color .3s
        }

        .form-control, .form-select {
            width: 100%;
            padding: 13px 13px 13px 38px;
            border: 1.5px solid #edf0f4;
            border-radius: 12px;
            font-family: 'Inter', sans-serif;
            font-size: .88rem;
            color: #1e293b;
            background: #fafbfc;
            appearance: none;
            outline: none;
            transition: border-color .25s, box-shadow .25s
        }

            .form-control:focus, .form-select:focus {
                border-color: var(--c);
                box-shadow: 0 0 0 3.5px var(--cr);
                background: #fff
            }

        .alert-ui {
            font-size: 0.72rem;
            color: #ef4444;
            margin-top: 5px;
            display: none;
            align-items: center;
            gap: 4px;
            font-weight: 500;
        }

        .info-hint {
            font-size: .75rem;
            color: #94a3b8;
            line-height: 1.5;
            margin-bottom: 4px;
            display: flex;
            align-items: flex-start;
            gap: 6px;
        }

            .info-hint i {
                color: var(--c);
                margin-top: 2px;
                flex-shrink: 0;
            }

        .btn-submit {
            width: 100%;
            padding: 15px 20px;
            border: none;
            border-radius: 14px;
            background: var(--c);
            color: #fff;
            font-family: 'Outfit', sans-serif;
            font-size: .82rem;
            font-weight: 600;
            letter-spacing: 1.8px;
            text-transform: uppercase;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-top: 22px;
            box-shadow: 0 10px 30px var(--cg);
            transition: all var(--speed);
            position: relative;
            overflow: hidden
        }

            .btn-submit:disabled {
                opacity: 0.7;
                cursor: not-allowed;
                filter: grayscale(0.5);
            }

        .btn-arrow {
            width: 28px;
            height: 28px;
            border-radius: 9px;
            background: rgba(255,255,255,.2);
            display: grid;
            place-items: center;
            font-size: 14px;
            transition: transform .3s
        }

        .card-footer {
            margin-top: 28px;
            padding-top: 18px;
            border-top: 1px solid #f1f5f9;
            display: flex;
            flex-direction: column;
            gap: 12px
        }

        .back-link {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            font-size: .72rem;
            color: #94a3b8;
            text-decoration: none;
            transition: color .2s;
            font-family: 'Outfit', sans-serif;
            font-weight: 600;
        }

            .back-link:hover {
                color: var(--c);
            }

        .r-panel {
            flex: 1;
            position: relative;
            background: #f8fafc;
            overflow: hidden;
            display: flex;
            align-items: flex-end
        }

        #geo-canvas {
            position: absolute;
            inset: 0;
            width: 100%;
            height: 100%;
            z-index: 1
        }

        .r-spotlight {
            position: absolute;
            inset: 0;
            z-index: 2;
            pointer-events: none
        }

        .r-overlay {
            position: absolute;
            inset: 0;
            z-index: 3;
            pointer-events: none;
            background: radial-gradient(ellipse 65% 55% at 65% 35%,transparent,rgba(255,255,255,.4) 80%), linear-gradient(180deg,transparent 45%,rgba(255,255,255,.95))
        }

        .r-text {
            position: relative;
            z-index: 5;
            padding: 52px 56px;
            max-width: 520px;
            margin-bottom: 40px;
        }

            .r-text p {
                color: #64748b;
            }

        .r-pill {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            background: rgba(0,0,0,.04);
            border: 1px solid rgba(0,0,0,.08);
            border-radius: 100px;
            padding: 6px 14px 6px 8px;
            font-size: .72rem;
            color: #475569;
            backdrop-filter: blur(8px);
            margin-bottom: 20px
        }

        .r-pill-dot {
            width: 7px;
            height: 7px;
            border-radius: 50%;
            background: var(--c);
            box-shadow: 0 0 8px var(--c);
            animation: sPulse 2s infinite
        }

        .r-text h2 {
            font-family: 'Outfit', sans-serif;
            font-size: clamp(2rem,3vw,2.9rem);
            font-weight: 800;
            color: #0f0f0f;
            line-height: 1.1;
            letter-spacing: -1px;
            margin-bottom: 14px
        }

            .r-text h2 em {
                font-style: normal;
                color: var(--c);
                transition: color var(--speed)
            }

        @@keyframes sPulse {
            0%, 100% {
                box-shadow: 0 0 0 0 rgba(34,197,94,.45)
            }

            55% {
                box-shadow: 0 0 0 5px rgba(34,197,94,0)
            }
        }

        @@keyframes rip {
            to {
                transform: scale(2.5);
                opacity: 0
            }
        }
    </style>
</head>
<body>

    <div class="shell">

        <!-- ===== PANEL IZQUIERDO ===== -->
        <div class="l-panel" id="lPanel">
            <div class="card-tilt" id="tiltWrap">
                <div class="card">

                    <div class="brand-row">
                        <div class="brand-icon">
                            <i class="bi bi-shield-lock-fill"></i>
                        </div>
                        <div class="brand-text">
                            <h1>SenaPay</h1>
                            <span>Recuperar acceso</span>
                        </div>
                    </div>

                    <div class="section-title">
                        <i class="bi bi-key-fill" style="font-size:12px;color:var(--c)"></i>
                        Verificación de identidad
                    </div>

                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div style="font-size:.76rem;color:#ef4444;background:rgba(239,68,68,.07);border:1px solid rgba(239,68,68,.15);border-radius:10px;padding:10px 12px;margin-bottom:16px;display:flex;align-items:center;gap:6px;font-weight:500;">
                            <i class="bi bi-exclamation-circle-fill"></i>
                            @Html.ValidationSummary(true)
                        </div>
                    }

                    <form asp-action="RecuperarPassword" method="post" id="recForm" onsubmit="return validateForm(event)">
                        @Html.AntiForgeryToken()

                        <div style="display:flex;gap:10px;">
                            <div class="field-group" style="width:44%">
                                <label class="field-label">Tipo doc.</label>
                                <div class="field-wrap">
                                    <i class="bi bi-card-text field-icon"></i>
                                    <select class="form-select" name="TipoDocumento">
                                        <option value="CC">CC</option>
                                        <option value="TI">TI</option>
                                    </select>
                                </div>
                            </div>
                            <div class="field-group" style="flex:1">
                                <label class="field-label" asp-for="Documento">Documento</label>
                                <div class="field-wrap">
                                    <i class="bi bi-hash field-icon"></i>
                                    <input asp-for="Documento"
                                           type="text"
                                           class="form-control"
                                           id="docField"
                                           placeholder="0000000000"
                                           maxlength="12"
                                           autofocus
                                           onkeypress="return isNumKey(event)" />
                                </div>
                                <div id="err-doc" class="alert-ui">
                                    <i class="bi bi-exclamation-circle"></i> Ingrese su documento
                                </div>
                                <span asp-validation-for="Documento" style="font-size:.72rem;color:#ef4444;margin-top:4px;display:block;"></span>
                            </div>
                        </div>

                        <p class="info-hint">
                            <i class="bi bi-info-circle"></i>
                            Ingresa tu número de documento y te enviaremos las instrucciones para restablecer tu contraseña.
                        </p>

                        <button type="submit" class="btn-submit" id="submitBtn" onclick="btnRipple(event)">
                            <span id="btnText">Enviar instrucciones</span>
                            <div class="btn-arrow"><i class="bi bi-send-fill"></i></div>
                        </button>

                    </form>

                    <div class="card-footer">
                        <div style="text-align:center;">
                            <a asp-controller="Home" asp-action="Index" class="back-link">
                                <i class="bi bi-arrow-left"></i> Volver al inicio de sesión
                            </a>
                        </div>
                        <div style="display:flex;justify-content:space-between;align-items:center;">
                            <div style="font-size:.72rem;color:#cbd5e1">By <strong>CTA S.S.C</strong></div>
                            <div style="display:flex;align-items:center;gap:5px;font-size:.68rem;color:#94a3b8">
                                <div style="width:6px;height:6px;border-radius:50%;background:#22c55e"></div>
                                SSL Seguro
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </div>

        <!-- ===== PANEL DERECHO ===== -->
        <div class="r-panel" id="rPanel">
            <svg id="geo-canvas" xmlns="http://www.w3.org/2000/svg"></svg>
            <div class="r-spotlight"></div>
            <div class="r-overlay"></div>
            <div class="r-text">
                <div class="r-pill">
                    <div class="r-pill-dot"></div> SENA · Colombia
                </div>
                <h2>Recupera tu<br><em>acceso seguro</em></h2>
                <p>Tu identidad digital está protegida. Sigue los pasos para restablecer tu contraseña de forma rápida y segura.</p>
            </div>
        </div>

    </div>

    <script>
        function isNumKey(e) {
            var c = e.which || e.keyCode;
            return (c >= 48 && c <= 57);
        }

        function validateForm(e) {
            var doc = document.getElementById('docField').value.trim();
            var valid = true;
            if (!doc) {
                document.getElementById('err-doc').style.display = 'flex';
                valid = false;
            } else {
                document.getElementById('err-doc').style.display = 'none';
            }
            if (valid) {
                if (!window.navigator.onLine) {
                    alert('No tienes conexión a internet.');
                    return false;
                }
                var btn = document.getElementById('submitBtn');
                btn.disabled = true;
                document.getElementById('btnText').innerText = 'Enviando...';
            }
            return valid;
        }

        var tiltWrap = document.getElementById('tiltWrap');
        var tx = 0, ty = 0, ttx = 0, tty = 0;

        document.getElementById('lPanel').addEventListener('mousemove', function (e) {
            var r = tiltWrap.getBoundingClientRect();
            ttx = (e.clientY - r.top  - r.height / 2) / r.height * -9;
            tty = (e.clientX - r.left - r.width  / 2) / r.width  *  9;
        });

        document.getElementById('lPanel').addEventListener('mouseleave', function () {
            ttx = 0; tty = 0;
        });

        function lerp(a, b, t) { return a + (b - a) * t; }

        (function loop() {
            tx = lerp(tx, ttx, .08);
            ty = lerp(ty, tty, .08);
            tiltWrap.style.transform =
                'perspective(900px) rotateX(' + tx.toFixed(2) + 'deg) rotateY(' + ty.toFixed(2) + 'deg)';
            requestAnimationFrame(loop);
        })();

        function btnRipple(e) {
            var r  = e.currentTarget.getBoundingClientRect();
            var sp = document.createElement('span');
            sp.style.cssText =
                'position:absolute;background:rgba(255,255,255,.3);border-radius:50%;'
                + 'width:100px;height:100px;'
                + 'left:' + (e.clientX - r.left - 50) + 'px;'
                + 'top:'  + (e.clientY - r.top  - 50) + 'px;'
                + 'transform:scale(0);animation:rip .6s ease-out';
            e.currentTarget.appendChild(sp);
            setTimeout(function () { sp.remove(); }, 600);
        }
    </script>

    @section Scripts {
        @{
            await Html.RenderPartialAsync("_ValidationScriptsPartial");
        }
    }

</body>
</html>