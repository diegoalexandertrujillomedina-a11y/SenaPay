<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>SenaPay | Panel Funcionario</title>

    <!-- Fuentes — idénticas al Login -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@500;700;800&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <style>
        /* ─── RESET & TOKENS ───────────────────────────────────────── */
        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        :root {
            /* Color primario del rol Funcionario — mismo token del Login */
            --c: #6D28D9;
            --cg: rgba(109,40,217,.18);
            --cr: rgba(109,40,217,.08);
            --cd: #5B21B6; /* variante oscura para hover */
            --speed: .45s;
            /* Neutros */
            --bg: #f4f6fb;
            --surface: #ffffff;
            --border: rgba(0,0,0,.06);
            --text-main: #0f0f1a;
            --text-muted: #64748b;
            --sidebar-w: 240px;
        }

        /* ─── DARK MODE ─────────────────────────────────────────────── */
        @@media (prefers-color-scheme: dark) {
            :root {
                --bg: #080810;
                --surface: #13131f;
                --border: rgba(255,255,255,.06);
                --text-main: #f0f0ff;
                --text-muted: #6b7a99;
            }

            .navbar {
                background: #0d0d1a !important;
                border-color: rgba(255,255,255,.05) !important;
            }

            .sidebar {
                background: #0d0d1a !important;
                border-color: rgba(255,255,255,.05) !important;
            }

            .card {
                background: #13131f !important;
                border-color: rgba(255,255,255,.05) !important;
            }

            .form-control,
            .form-select {
                background: #1c1c2e !important;
                border-color: #2a2a3e !important;
                color: #e2e8f0 !important;
            }

            .field-label {
                color: #4a5578;
            }

            .stat-card {
                background: #13131f !important;
                border-color: rgba(255,255,255,.05) !important;
            }

            .nav-link-item {
                color: #8899bb;
            }

                .nav-link-item:hover,
                .nav-link-item.active {
                    background: rgba(109,40,217,.18) !important;
                    color: #a78bfa !important;
                }

            .toast-panel {
                background: #1c1c2e;
                border-color: rgba(255,255,255,.08);
                color: #e2e8f0;
            }
        }

        /* ─── BASE ──────────────────────────────────────────────────── */
        html, body {
            height: 100%;
            font-family: 'Inter', sans-serif;
            background: var(--bg);
            color: var(--text-main);
            -webkit-font-smoothing: antialiased;
        }

        /* ─── LAYOUT SHELL ──────────────────────────────────────────── */
        .shell {
            display: flex;
            height: 100vh;
            overflow: hidden;
        }

        /* ─── SIDEBAR ───────────────────────────────────────────────── */
        .sidebar {
            width: var(--sidebar-w);
            background: var(--surface);
            border-right: 1px solid var(--border);
            display: flex;
            flex-direction: column;
            flex-shrink: 0;
            transition: transform .35s cubic-bezier(.4,0,.2,1);
            z-index: 50;
            overflow: hidden;
        }

        .sidebar-brand {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 22px 20px;
            border-bottom: 1px solid var(--border);
        }

        .brand-icon {
            width: 40px;
            height: 40px;
            border-radius: 12px;
            background: var(--c);
            display: grid;
            place-items: center;
            color: #fff;
            font-size: 18px;
            box-shadow: 0 6px 18px var(--cg);
            flex-shrink: 0;
        }

        .brand-name {
            font-family: 'Outfit', sans-serif;
            font-size: 1.25rem;
            font-weight: 800;
            color: var(--text-main);
            letter-spacing: -.4px;
        }

        .brand-sub {
            font-size: .62rem;
            color: var(--text-muted);
            letter-spacing: .4px;
        }

        /* Nav items */
        .sidebar-nav {
            flex: 1;
            padding: 16px 10px;
            overflow-y: auto;
        }

        .nav-section-label {
            font-family: 'Outfit', sans-serif;
            font-size: .58rem;
            font-weight: 700;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 1.4px;
            padding: 0 10px;
            margin: 14px 0 6px;
        }

        .nav-link-item {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 11px 12px;
            border-radius: 10px;
            font-size: .82rem;
            font-weight: 500;
            color: var(--text-muted);
            text-decoration: none;
            cursor: pointer;
            border: none;
            background: transparent;
            width: 100%;
            transition: background .2s, color .2s;
        }

            .nav-link-item i {
                font-size: 16px;
                flex-shrink: 0;
            }

            .nav-link-item:hover,
            .nav-link-item.active {
                background: rgba(109,40,217,.1);
                color: var(--c);
            }

        .nav-badge {
            margin-left: auto;
            background: var(--c);
            color: #fff;
            font-size: .6rem;
            font-weight: 700;
            padding: 2px 7px;
            border-radius: 99px;
        }

        /* Sidebar footer */
        .sidebar-footer {
            padding: 16px 10px;
            border-top: 1px solid var(--border);
        }

        .user-chip {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px 12px;
            border-radius: 12px;
            background: rgba(109,40,217,.07);
            border: 1px solid rgba(109,40,217,.12);
        }

        .user-avatar {
            width: 34px;
            height: 34px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--c), #a78bfa);
            display: grid;
            place-items: center;
            color: #fff;
            font-size: 14px;
            flex-shrink: 0;
        }

        .user-name {
            font-family: 'Outfit', sans-serif;
            font-size: .8rem;
            font-weight: 700;
            color: var(--text-main);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            max-width: 110px;
        }

        .user-role-tag {
            font-size: .6rem;
            color: var(--c);
            font-weight: 600;
            letter-spacing: .5px;
        }

        /* ─── MAIN CONTENT ──────────────────────────────────────────── */
        .main {
            flex: 1;
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

        /* ─── NAVBAR (top) ──────────────────────────────────────────── */
        .navbar {
            height: 62px;
            background: var(--surface);
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            padding: 0 24px;
            gap: 14px;
            flex-shrink: 0;
            z-index: 30;
        }

        .nav-hamburger {
            display: none;
            border: none;
            background: none;
            font-size: 20px;
            color: var(--text-muted);
            cursor: pointer;
            padding: 6px;
        }

        .nav-title {
            font-family: 'Outfit', sans-serif;
            font-size: 1rem;
            font-weight: 700;
            color: var(--text-main);
        }

        .nav-breadcrumb {
            font-size: .72rem;
            color: var(--text-muted);
            display: flex;
            align-items: center;
            gap: 5px;
        }

            .nav-breadcrumb i {
                font-size: 10px;
            }

        .nav-spacer {
            flex: 1;
        }

        /* Pill de estado del sistema */
        .status-pill {
            display: flex;
            align-items: center;
            gap: 6px;
            background: rgba(34,197,94,.08);
            border: 1px solid rgba(34,197,94,.18);
            border-radius: 100px;
            padding: 5px 12px;
            font-size: .68rem;
            color: #16a34a;
            font-weight: 600;
        }

        .status-dot {
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: #22c55e;
            box-shadow: 0 0 6px rgba(34,197,94,.7);
            animation: pulse 2s infinite;
        }

        @@keyframes pulse {
            0%, 100% {
                box-shadow: 0 0 0 0 rgba(34,197,94,.5);
            }

            50% {
                box-shadow: 0 0 0 5px rgba(34,197,94,0);
            }
        }

        /* Botón cerrar sesión */
        .btn-logout {
            display: flex;
            align-items: center;
            gap: 7px;
            padding: 8px 16px;
            border-radius: 10px;
            background: rgba(239,68,68,.07);
            border: 1px solid rgba(239,68,68,.15);
            color: #ef4444;
            font-family: 'Outfit', sans-serif;
            font-size: .75rem;
            font-weight: 700;
            letter-spacing: .5px;
            cursor: pointer;
            text-decoration: none;
            transition: background .2s, border-color .2s, transform .15s;
        }

            .btn-logout:hover {
                background: rgba(239,68,68,.14);
                border-color: rgba(239,68,68,.3);
                transform: translateY(-1px);
            }

        /* ─── PAGE BODY ─────────────────────────────────────────────── */
        .page-body {
            flex: 1;
            overflow-y: auto;
            padding: 28px 28px 48px;
            scroll-behavior: smooth;
        }

        /* ─── STAT CARDS ─────────────────────────────────────────────── */
        .stats-row {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
            gap: 16px;
            margin-bottom: 28px;
            animation: slideUp .6s cubic-bezier(.22,1,.36,1) both;
        }

        .stat-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 18px;
            padding: 20px;
            display: flex;
            flex-direction: column;
            gap: 8px;
            transition: transform .2s, box-shadow .2s;
        }

            .stat-card:hover {
                transform: translateY(-2px);
                box-shadow: 0 8px 28px rgba(0,0,0,.08);
            }

        .stat-icon {
            width: 38px;
            height: 38px;
            border-radius: 11px;
            display: grid;
            place-items: center;
            font-size: 17px;
            margin-bottom: 4px;
        }

        .stat-value {
            font-family: 'Outfit', sans-serif;
            font-size: 1.6rem;
            font-weight: 800;
            color: var(--text-main);
            line-height: 1;
        }

        .stat-label {
            font-size: .7rem;
            color: var(--text-muted);
            font-weight: 500;
        }

        .stat-delta {
            font-size: .68rem;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 3px;
            margin-top: 2px;
        }

        .delta-up {
            color: #22c55e;
        }

        .delta-down {
            color: #ef4444;
        }

        /* ─── SECTION HEADER ─────────────────────────────────────────── */
        .section-header {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 18px;
        }

        .section-icon {
            width: 36px;
            height: 36px;
            border-radius: 10px;
            background: rgba(109,40,217,.1);
            display: grid;
            place-items: center;
            color: var(--c);
            font-size: 16px;
        }

        .section-title {
            font-family: 'Outfit', sans-serif;
            font-size: 1.05rem;
            font-weight: 700;
            color: var(--text-main);
        }

        .section-sub {
            font-size: .72rem;
            color: var(--text-muted);
        }

        /* ─── CARD BASE ──────────────────────────────────────────────── */
        .card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 20px;
            padding: 28px;
            box-shadow: 0 2px 12px rgba(0,0,0,.04);
            animation: slideUp .65s cubic-bezier(.22,1,.36,1) .05s both;
        }

        @@keyframes slideUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* ─── FORM STYLES ────────────────────────────────────────────── */
        .form-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 16px;
        }

        .field-group {
            display: flex;
            flex-direction: column;
            gap: 6px;
        }

            .field-group.full {
                grid-column: 1 / -1;
            }

        .field-label {
            font-family: 'Outfit', sans-serif;
            font-size: .64rem;
            font-weight: 700;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 1.2px;
        }

        .field-wrap {
            position: relative;
        }

        .field-icon {
            position: absolute;
            left: 13px;
            top: 50%;
            transform: translateY(-50%);
            color: #b0bec5;
            font-size: 14px;
            pointer-events: none;
            transition: color .25s;
        }

        /* → El selector de moneda tiene ícono especial */
        .field-prefix {
            position: absolute;
            left: 13px;
            top: 50%;
            transform: translateY(-50%);
            font-size: .75rem;
            font-weight: 700;
            color: #b0bec5;
            pointer-events: none;
            font-family: 'Outfit', sans-serif;
        }

        .form-control,
        .form-select {
            width: 100%;
            padding: 12px 12px 12px 38px;
            border: 1.5px solid #e9edf3;
            border-radius: 12px;
            font-family: 'Inter', sans-serif;
            font-size: .86rem;
            color: var(--text-main);
            background: #fafbfc;
            appearance: none;
            outline: none;
            transition: border-color .25s, box-shadow .25s;
        }

            /* Campo de saldo con prefijo de texto */
            .form-control.with-prefix {
                padding-left: 42px;
            }

            .form-control:focus,
            .form-select:focus {
                border-color: var(--c);
                box-shadow: 0 0 0 3.5px var(--cr);
                background: #fff;
            }

        /* Error inline */
        .field-error {
            font-size: .67rem;
            color: #ef4444;
            display: none;
            align-items: center;
            gap: 4px;
            font-weight: 500;
        }

        /* Divider del formulario */
        .form-divider {
            grid-column: 1 / -1;
            border: none;
            border-top: 1px solid var(--border);
            margin: 6px 0;
        }

        /* ─── SUBMIT BUTTON ──────────────────────────────────────────── */
        .btn-primary {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            padding: 14px 28px;
            border: none;
            border-radius: 13px;
            background: var(--c);
            color: #fff;
            font-family: 'Outfit', sans-serif;
            font-size: .82rem;
            font-weight: 700;
            letter-spacing: 1.4px;
            text-transform: uppercase;
            cursor: pointer;
            box-shadow: 0 8px 24px var(--cg);
            transition: background .3s, transform .2s, box-shadow .3s;
            position: relative;
            overflow: hidden;
        }

            .btn-primary:hover:not(:disabled) {
                background: var(--cd);
                transform: translateY(-2px);
                box-shadow: 0 12px 32px var(--cg);
            }

            .btn-primary:disabled {
                opacity: .65;
                cursor: not-allowed;
                filter: grayscale(.4);
            }

        .btn-icon-box {
            width: 26px;
            height: 26px;
            border-radius: 8px;
            background: rgba(255,255,255,.2);
            display: grid;
            place-items: center;
            font-size: 13px;
        }

        /* ─── TOAST NOTIFICATION ─────────────────────────────────────── */
        .toast-panel {
            position: fixed;
            bottom: 28px;
            right: 28px;
            min-width: 300px;
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: 16px 18px;
            display: flex;
            align-items: flex-start;
            gap: 12px;
            box-shadow: 0 16px 48px rgba(0,0,0,.14);
            z-index: 9999;
            transform: translateY(80px);
            opacity: 0;
            pointer-events: none;
            transition: transform .4s cubic-bezier(.34,1.2,.64,1), opacity .3s;
        }

            .toast-panel.show {
                transform: translateY(0);
                opacity: 1;
                pointer-events: auto;
            }

        .toast-icon {
            width: 36px;
            height: 36px;
            border-radius: 10px;
            display: grid;
            place-items: center;
            font-size: 17px;
            flex-shrink: 0;
        }

            .toast-icon.success {
                background: rgba(34,197,94,.12);
                color: #16a34a;
            }

            .toast-icon.error {
                background: rgba(239,68,68,.10);
                color: #ef4444;
            }

        .toast-title {
            font-family: 'Outfit',sans-serif;
            font-size: .85rem;
            font-weight: 700;
            color: var(--text-main);
        }

        .toast-msg {
            font-size: .72rem;
            color: var(--text-muted);
            margin-top: 2px;
        }

        .toast-close {
            margin-left: auto;
            background: none;
            border: none;
            cursor: pointer;
            color: var(--text-muted);
            font-size: 16px;
            padding: 2px;
        }

        /* ─── RECENT TABLE ───────────────────────────────────────────── */
        .table-wrap {
            overflow-x: auto;
            margin-top: 24px;
        }

        table.sp-table {
            width: 100%;
            border-collapse: collapse;
            font-size: .8rem;
        }

        .sp-table thead th {
            font-family: 'Outfit', sans-serif;
            font-size: .62rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: var(--text-muted);
            padding: 10px 14px;
            text-align: left;
            border-bottom: 1px solid var(--border);
            white-space: nowrap;
        }

        .sp-table tbody td {
            padding: 13px 14px;
            border-bottom: 1px solid var(--border);
            color: var(--text-main);
            vertical-align: middle;
        }

        .sp-table tbody tr:last-child td {
            border-bottom: none;
        }

        .sp-table tbody tr:hover td {
            background: rgba(109,40,217,.03);
        }

        /* Role badge */
        .role-badge {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            padding: 4px 10px;
            border-radius: 99px;
            font-size: .65rem;
            font-weight: 700;
            font-family: 'Outfit', sans-serif;
            letter-spacing: .4px;
        }

        .badge-aprendiz {
            background: rgba(57,169,0,.1);
            color: #39A900;
        }

        .badge-tienda {
            background: rgba(232,108,0,.1);
            color: #E86C00;
        }

        .badge-funcionario {
            background: rgba(109,40,217,.1);
            color: #6D28D9;
        }

        /* ─── OVERLAY (móvil sidebar) ────────────────────────────────── */
        .sidebar-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,.4);
            z-index: 40;
            backdrop-filter: blur(2px);
        }

        /* ─── RESPONSIVE ─────────────────────────────────────────────── */
        @@media (max-width: 768px) {
            .shell {
                position: relative;
            }

            .sidebar {
                position: fixed;
                top: 0;
                left: 0;
                bottom: 0;
                transform: translateX(-100%);
            }

                .sidebar.open {
                    transform: translateX(0);
                }

            .sidebar-overlay {
                display: block;
            }

                .sidebar-overlay.active {
                    display: block;
                }

            .nav-hamburger {
                display: flex;
            }

            .status-pill {
                display: none;
            }

            .form-grid {
                grid-template-columns: 1fr;
            }

            .field-group.full {
                grid-column: 1;
            }

            .page-body {
                padding: 20px 16px 48px;
            }

            .navbar {
                padding: 0 16px;
            }

            .stats-row {
                grid-template-columns: repeat(2, 1fr);
            }
        }

        @@media (max-width: 400px) {
            .stats-row {
                grid-template-columns: 1fr;
            }

            .btn-logout span {
                display: none;
            }
        }

        /* ─── SPINNER ────────────────────────────────────────────────── */
        .spinner {
            width: 16px;
            height: 16px;
            border: 2px solid rgba(255,255,255,.4);
            border-top-color: #fff;
            border-radius: 50%;
            animation: spin .6s linear infinite;
            display: none;
        }

        @@keyframes spin {
            to {
                transform: rotate(360deg);
            }
        }
    </style>
</head>
<body>

    <div class="shell">

        <!-- ═══════════════════════════════════════════════
             SIDEBAR
        ═══════════════════════════════════════════════ -->
        <aside class="sidebar" id="sidebar">

            <div class="sidebar-brand">
                <div class="brand-icon">
                    <i class="bi bi-briefcase-fill"></i>
                </div>
                <div>
                    <div class="brand-name">SenaPay</div>
                    <div class="brand-sub">SENA · Ecosistema Digital</div>
                </div>
            </div>

            <nav class="sidebar-nav">
                <div class="nav-section-label">Principal</div>

                <!-- → Cambia href por asp-action / asp-controller en Razor -->
                <button class="nav-link-item active" onclick="showSection('usuarios')">
                    <i class="bi bi-people-fill"></i>
                    Usuarios
                    <span class="nav-badge" id="badge-usuarios">0</span>
                </button>

                <button class="nav-link-item" onclick="showSection('reportes')">
                    <i class="bi bi-bar-chart-fill"></i>
                    Reportes
                </button>

                <div class="nav-section-label">Sistema</div>

                <button class="nav-link-item" onclick="showSection('config')">
                    <i class="bi bi-gear-fill"></i>
                    Configuración
                </button>

                <!-- Cerrar sesión también en sidebar para móvil -->
                <a class="nav-link-item" href="/Account/Logout"
                   style="color:#ef4444; margin-top:8px;"
                   onclick="return confirm('¿Confirmas que deseas cerrar sesión?')">
                    <i class="bi bi-box-arrow-left"></i>
                    Cerrar sesión
                </a>
            </nav>

            <!-- Usuario logueado en sidebar -->
            <div class="sidebar-footer">
                <div class="user-chip">
                    <div class="user-avatar">
                        <i class="bi bi-person-fill"></i>
                    </div>
                    <div>
                        @*
                    Nombre real del usuario autenticado.
                    En Razor usa: User.Identity.Name
                    O desde Claims: User.FindFirst("Nombre")?.Value
                *@
                        <div class="user-name">@nombreUsuario</div>
                        <div class="user-role-tag">FUNCIONARIO</div>
                    </div>
                </div>
            </div>
        </aside>

        <!-- Overlay para cerrar sidebar en móvil -->
        <div class="sidebar-overlay" id="sidebarOverlay" onclick="closeSidebar()"></div>

        <!-- ═══════════════════════════════════════════════
             MAIN CONTENT
        ═══════════════════════════════════════════════ -->
        <div class="main">

            <!-- NAVBAR TOP -->
            <header class="navbar">
                <button class="nav-hamburger" id="hamburger" onclick="openSidebar()">
                    <i class="bi bi-list"></i>
                </button>

                <div>
                    <div class="nav-title">Panel Funcionario</div>
                    <div class="nav-breadcrumb">
                        <span>SenaPay</span>
                        <i class="bi bi-chevron-right"></i>
                        <span id="breadcrumb-current">Gestión de Usuarios</span>
                    </div>
                </div>

                <div class="nav-spacer"></div>

                <!-- Indicador de sistema online -->
                <div class="status-pill">
                    <div class="status-dot"></div>
                    Sistema operativo
                </div>

                <!--
                    BOTÓN CERRAR SESIÓN
                    → asp-controller="Account" asp-action="Logout"
                    → El href apunta al endpoint de logout de tu controlador Account.
                    → Reemplaza href por el tag helper Razor para mayor seguridad.
                    → Recomendado: usar un form POST para logout (prevenir CSRF en GET).
                -->
                <a href="/Account/Logout" class="btn-logout"
                   onclick="return confirm('¿Confirmas que deseas cerrar sesión?')">
                    <i class="bi bi-box-arrow-right"></i>
                    <span>Cerrar sesión</span>
                </a>
            </header>

            <!-- PAGE BODY -->
            <div class="page-body" id="pageBody">

                <!-- ─── TARJETAS DE ESTADÍSTICAS ─── -->
                <div class="stats-row">
                    <div class="stat-card">
                        <div class="stat-icon" style="background:rgba(109,40,217,.1); color:#6D28D9;">
                            <i class="bi bi-people-fill"></i>
                        </div>
                        <div class="stat-value" id="stat-total">—</div>
                        <div class="stat-label">Usuarios totales</div>
                        <div class="stat-delta delta-up"><i class="bi bi-arrow-up-short"></i> Activos</div>
                    </div>

                    <div class="stat-card">
                        <div class="stat-icon" style="background:rgba(57,169,0,.1); color:#39A900;">
                            <i class="bi bi-person-badge-fill"></i>
                        </div>
                        <div class="stat-value" id="stat-aprendiz">—</div>
                        <div class="stat-label">Aprendices</div>
                        <div class="stat-delta delta-up"><i class="bi bi-arrow-up-short"></i> Registrados</div>
                    </div>

                    <div class="stat-card">
                        <div class="stat-icon" style="background:rgba(232,108,0,.1); color:#E86C00;">
                            <i class="bi bi-shop"></i>
                        </div>
                        <div class="stat-value" id="stat-tienda">—</div>
                        <div class="stat-label">Tiendas</div>
                        <div class="stat-delta delta-up"><i class="bi bi-arrow-up-short"></i> Habilitadas</div>
                    </div>

                    <div class="stat-card">
                        <div class="stat-icon" style="background:rgba(234,179,8,.1); color:#ca8a04;">
                            <i class="bi bi-wallet2"></i>
                        </div>
                        <div class="stat-value" id="stat-saldo">—</div>
                        <div class="stat-label">Saldo en circulación</div>
                        <div class="stat-delta delta-up"><i class="bi bi-arrow-up-short"></i> COP</div>
                    </div>
                </div>

                <!-- ─── SECCIÓN: AGREGAR USUARIO ─── -->
                <div id="section-usuarios">
                    <div class="section-header">
                        <div class="section-icon"><i class="bi bi-person-plus-fill"></i></div>
                        <div>
                            <div class="section-title">Agregar Usuario</div>
                            <div class="section-sub">Registra un nuevo usuario en el ecosistema SenaPay</div>
                        </div>
                    </div>

                    <div class="card">
                        <!--
                            ══════════════════════════════════════════════════
                            FORMULARIO — AGREGAR USUARIO

                            INTEGRACIÓN CON RAZOR/C#:
                            • No usamos asp-action aquí porque el envío es
                              via fetch (AJAX) para obtener la respuesta JSON
                              sin recargar la página.
                            • El antiforgery token se inyecta en el header
                              de la petición fetch (ver JS más abajo).
                            • El modelo destino es: Models/UsuarioViewModel.cs
                            ══════════════════════════════════════════════════
                        -->
                        <form id="formAgregarUsuario" novalidate>
                            @Html.AntiForgeryToken()

                            <div class="form-grid">

                                <!-- NOMBRE -->
                                <div class="field-group">
                                    <label class="field-label" for="fNombre">Nombre completo</label>
                                    <div class="field-wrap">
                                        <i class="bi bi-person field-icon"></i>
                                        <!--
                                            → name="Nombre" debe coincidir con la
                                              propiedad del ViewModel: UsuarioViewModel.Nombre
                                        -->
                                        <input type="text" class="form-control" id="fNombre"
                                               name="Nombre" placeholder="Ej. María Fernanda López"
                                               autocomplete="off" />
                                    </div>
                                    <div class="field-error" id="err-nombre">
                                        <i class="bi bi-exclamation-circle"></i> Ingresa el nombre completo
                                    </div>
                                </div>

                                <!-- ROL -->
                                <div class="field-group">
                                    <label class="field-label" for="fRol">Rol del usuario</label>
                                    <div class="field-wrap">
                                        <i class="bi bi-shield-fill-check field-icon"></i>
                                        <!--
                                            → name="Rol" → UsuarioViewModel.Rol
                                            → Valores: "Aprendiz" | "Tienda" | "Funcionario"
                                            → En tu controlador valida que solo Funcionario pueda asignar Funcionario
                                        -->
                                        <select class="form-select" id="fRol" name="Rol">
                                            <option value="">— Selecciona un rol —</option>
                                            <option value="Aprendiz">Aprendiz</option>
                                            <option value="Tienda">Tienda</option>
                                            <option value="Funcionario">Funcionario</option>
                                        </select>
                                    </div>
                                    <div class="field-error" id="err-rol">
                                        <i class="bi bi-exclamation-circle"></i> Selecciona un rol
                                    </div>
                                </div>

                                <hr class="form-divider" />

                                <!-- TIPO DOCUMENTO -->
                                <div class="field-group">
                                    <label class="field-label" for="fTipoDoc">Tipo de documento</label>
                                    <div class="field-wrap">
                                        <i class="bi bi-card-text field-icon"></i>
                                        <!--
                                            → name="TipoDocumento" → UsuarioViewModel.TipoDocumento
                                        -->
                                        <select class="form-select" id="fTipoDoc" name="TipoDocumento">
                                            <option value="CC">CC — Cédula de ciudadanía</option>
                                            <option value="TI">TI — Tarjeta de identidad</option>
                                            <option value="CE">CE — Cédula de extranjería</option>
                                            <option value="PAS">PAS — Pasaporte</option>
                                        </select>
                                    </div>
                                </div>

                                <!-- NÚMERO DOCUMENTO -->
                                <div class="field-group">
                                    <label class="field-label" for="fDocumento">Número de documento</label>
                                    <div class="field-wrap">
                                        <i class="bi bi-hash field-icon"></i>
                                        <!--
                                            → name="Documento" → UsuarioViewModel.Documento
                                            → Validación: solo numérico (ver JS validateDocumento())
                                        -->
                                        <input type="text" class="form-control" id="fDocumento"
                                               name="Documento" placeholder="0000000000"
                                               maxlength="12" autocomplete="off"
                                               onkeypress="return soloNumeros(event)"
                                               oninput="limpiarError('err-documento')" />
                                    </div>
                                    <div class="field-error" id="err-documento">
                                        <i class="bi bi-exclamation-circle"></i> El documento debe ser numérico
                                    </div>
                                </div>

                                <!-- SALDO INICIAL -->
                                <div class="field-group full">
                                    <label class="field-label" for="fSaldo">Saldo inicial (COP)</label>
                                    <div class="field-wrap">
                                        <!--
                                            Prefijo "$" como indicador visual.
                                            → name="SaldoInicial" → UsuarioViewModel.SaldoInicial (decimal)
                                            → En el servidor convierte con: decimal.TryParse(...)
                                        -->
                                        <span class="field-prefix">$</span>
                                        <input type="number" class="form-control with-prefix"
                                               id="fSaldo" name="SaldoInicial"
                                               placeholder="0" min="0" step="100"
                                               value="0" />
                                    </div>
                                    <div class="field-error" id="err-saldo">
                                        <i class="bi bi-exclamation-circle"></i> El saldo no puede ser negativo
                                    </div>
                                </div>

                            </div><!-- /form-grid -->
                            <!-- BOTÓN ENVIAR -->
                            <div style="margin-top:24px; display:flex; justify-content:flex-end;">
                                <button type="submit" class="btn-primary" id="btnAgregar">
                                    <div class="spinner" id="btnSpinner"></div>
                                    <span id="btnTexto">Agregar usuario</span>
                                    <div class="btn-icon-box">
                                        <i class="bi bi-person-plus-fill"></i>
                                    </div>
                                </button>
                            </div>

                        </form>

                        <!-- TABLA DE USUARIOS REGISTRADOS (se puebla desde JS) -->
                        <div class="table-wrap">
                            <div class="section-header" style="margin-top:24px; margin-bottom:0;">
                                <div>
                                    <div class="section-title" style="font-size:.9rem;">Usuarios registrados</div>
                                </div>
                            </div>
                            <table class="sp-table" id="tablaUsuarios">
                                <thead>
                                    <tr>
                                        <th>Nombre</th>
                                        <th>Documento</th>
                                        <th>Tipo</th>
                                        <th>Rol</th>
                                        <th>Saldo</th>
                                        <th>Fecha alta</th>
                                    </tr>
                                </thead>
                                <tbody id="tbodyUsuarios">
                                    @*
                                    → Aquí se insertarán filas dinámicamente desde JS
                                    → También puedes renderizarlas desde Razor con:
                                      @@foreach(var u in Model.Usuarios) { ... }
                                    → Usando un ViewModel: FuncionarioDashboardViewModel
                                      con IEnumerable<UsuarioViewModel> Usuarios
                                *@
                                    <tr id="emptyRow">
                                        <td colspan="6" style="text-align:center; padding:32px; color:var(--text-muted);">
                                            <i class="bi bi-inbox" style="font-size:1.4rem; display:block; margin-bottom:8px;"></i>
                                            Aún no hay usuarios registrados
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>

                    </div><!-- /card -->
                </div><!-- /section-usuarios -->

            </div><!-- /page-body -->
        </div><!-- /main -->
    </div><!-- /shell -->
    <!-- ─── TOAST NOTIFICATION ─── -->
    <div class="toast-panel" id="toastPanel">
        <div class="toast-icon" id="toastIcon">
            <i class="bi bi-check2" id="toastIco"></i>
        </div>
        <div style="flex:1;">
            <div class="toast-title" id="toastTitle"></div>
            <div class="toast-msg" id="toastMsg"></div>
        </div>
        <button class="toast-close" onclick="hideToast()"><i class="bi bi-x"></i></button>
    </div>


    <!-- ═══════════════════════════════════════════════════════════════
         JAVASCRIPT
         ═══════════════════════════════════════════════════════════════ -->
    <script>
        /*
         * ─────────────────────────────────────────────────────────────
         * ESTADO LOCAL — simula la lista de usuarios en memoria.
         * En producción esta lista se puebla desde el servidor vía
         * fetch GET a /Funcionario/ObtenerUsuarios (JSON).
         * ─────────────────────────────────────────────────────────────
         */
        let usuarios = [];   // → Aquí vivirán los usuarios cargados/creados

        // ── Sidebar móvil ─────────────────────────────────────────────
        function openSidebar() {
            document.getElementById('sidebar').classList.add('open');
            document.getElementById('sidebarOverlay').classList.add('active');
        }
        function closeSidebar() {
            document.getElementById('sidebar').classList.remove('open');
            document.getElementById('sidebarOverlay').classList.remove('active');
        }

        // ── Navegación de secciones ───────────────────────────────────
        function showSection(sec) {
            document.querySelectorAll('.nav-link-item').forEach(el => el.classList.remove('active'));
            event.currentTarget.classList.add('active');
            document.getElementById('breadcrumb-current').textContent =
                sec === 'usuarios' ? 'Gestión de Usuarios' :
                sec === 'reportes' ? 'Reportes' : 'Configuración';
            closeSidebar();
            // → Aquí puedes cargar vistas parciales vía AJAX si lo deseas
        }

        // ── Solo numérico ─────────────────────────────────────────────
        // Validación client-side: solo dígitos en campo Documento.
        // En el ViewModel agrega: [RegularExpression("^[0-9]+$")]
        function soloNumeros(e) {
            const c = e.which || e.keyCode;
            return (c >= 48 && c <= 57);
        }

        // ── Limpia error al escribir ──────────────────────────────────
        function limpiarError(id) {
            document.getElementById(id).style.display = 'none';
        }

        // ── Mostrar / ocultar error ───────────────────────────────────
        function showError(id, show) {
            document.getElementById(id).style.display = show ? 'flex' : 'none';
        }

        // ── Validación del formulario (client-side) ───────────────────
        function validarFormulario() {
            let ok = true;

            const nombre = document.getElementById('fNombre').value.trim();
            const rol    = document.getElementById('fRol').value;
            const doc    = document.getElementById('fDocumento').value.trim();
            const saldo  = parseFloat(document.getElementById('fSaldo').value);

            showError('err-nombre',   !nombre);
            showError('err-rol',      !rol);
            showError('err-documento', !doc || !/^\d+$/.test(doc));
            showError('err-saldo',    saldo < 0 || isNaN(saldo));

            if (!nombre || !rol || !doc || !/^\d+$/.test(doc) || saldo < 0 || isNaN(saldo)) {
                ok = false;
            }

            return ok;
        }

        // ── TOAST ─────────────────────────────────────────────────────
        let toastTimer;
        function showToast(type, title, msg) {
            const panel = document.getElementById('toastPanel');
            const icon  = document.getElementById('toastIcon');
            const ico   = document.getElementById('toastIco');
            document.getElementById('toastTitle').textContent = title;
            document.getElementById('toastMsg').textContent   = msg;

            icon.className = `toast-icon ${type}`;
            ico.className  = type === 'success' ? 'bi bi-check2-circle' : 'bi bi-x-circle';

            panel.classList.add('show');
            clearTimeout(toastTimer);
            toastTimer = setTimeout(hideToast, 4500);
        }

        function hideToast() {
            document.getElementById('toastPanel').classList.remove('show');
        }

        // ── Render tabla ──────────────────────────────────────────────
        function renderTabla() {
            const tbody = document.getElementById('tbodyUsuarios');
            const emptyRow = document.getElementById('emptyRow');

            if (usuarios.length === 0) {
                emptyRow.style.display = '';
                return;
            }
            emptyRow.style.display = 'none';

            // Limpia filas previas (excepto emptyRow)
            tbody.querySelectorAll('tr:not(#emptyRow)').forEach(r => r.remove());

            const badgeClass = { Aprendiz:'badge-aprendiz', Tienda:'badge-tienda', Funcionario:'badge-funcionario' };
            const badgeIcon  = { Aprendiz:'bi-person-badge-fill', Tienda:'bi-shop', Funcionario:'bi-briefcase-fill' };

            usuarios.forEach(u => {
                const tr = document.createElement('tr');
                tr.innerHTML = `
                    <td style="font-weight:600;">${escHtml(u.Nombre)}</td>
                    <td style="font-family:'Outfit',sans-serif;">${escHtml(u.Documento)}</td>
                    <td>${escHtml(u.TipoDocumento)}</td>
                    <td>
                        <span class="role-badge ${badgeClass[u.Rol] || ''}">
                            <i class="bi ${badgeIcon[u.Rol] || 'bi-person'}"></i>
                            ${escHtml(u.Rol)}
                        </span>
                    </td>
                    <td style="font-family:'Outfit',sans-serif; font-weight:700;">
                        $${Number(u.SaldoInicial).toLocaleString('es-CO')}
                    </td>
                    <td style="color:var(--text-muted); font-size:.75rem;">${u.FechaAlta}</td>
                `;
                tbody.appendChild(tr);
            });

            actualizarEstadisticas();
        }

        function escHtml(str) {
            return String(str)
                .replace(/&/g,'&amp;').replace(/</g,'&lt;')
                .replace(/>/g,'&gt;').replace(/"/g,'&quot;');
        }

        // ── Estadísticas locales ──────────────────────────────────────
        function actualizarEstadisticas() {
            const total    = usuarios.length;
            const aprendiz = usuarios.filter(u => u.Rol === 'Aprendiz').length;
            const tienda   = usuarios.filter(u => u.Rol === 'Tienda').length;
            const saldo    = usuarios.reduce((a, u) => a + (parseFloat(u.SaldoInicial) || 0), 0);

            document.getElementById('stat-total').textContent   = total;
            document.getElementById('stat-aprendiz').textContent = aprendiz;
            document.getElementById('stat-tienda').textContent   = tienda;
            document.getElementById('stat-saldo').textContent    = '$' + saldo.toLocaleString('es-CO');
            document.getElementById('badge-usuarios').textContent = total;
        }

        /*
         * ─────────────────────────────────────────────────────────────
         * ENVÍO DEL FORMULARIO VIA FETCH (AJAX)
         *
         * INTEGRACIÓN C# / ASP.NET Core:
         *
         * 1. El antiforgery token se lee del campo oculto __RequestVerificationToken
         *    que Razor inyecta con Html.AntiForgeryToken() en la vista.
         *
         * 2. Se hace un POST a /Funcionario/AgregarUsuario (JSON).
         *
         * 3. El controlador debe tener:
         *      [HttpPost, ValidateAntiForgeryToken]
         *      public async Task<IActionResult> AgregarUsuario([FromBody] UsuarioViewModel model)
         *    Nota: con [FromBody] el header Content-Type debe ser application/json.
         *    Si prefieres [FromForm], cambia el body a FormData en lugar de JSON.stringify.
         *
         * 4. El servidor responde con JSON: { ok: true, msg: "...", usuario: {...} }
         * ─────────────────────────────────────────────────────────────
         */
        document.getElementById('formAgregarUsuario').addEventListener('submit', async function(e) {
            e.preventDefault();

            if (!validarFormulario()) return;

            // → Estado de carga
            const btn     = document.getElementById('btnAgregar');
            const spinner = document.getElementById('btnSpinner');
            const texto   = document.getElementById('btnTexto');

            btn.disabled      = true;
            spinner.style.display = 'block';
            texto.textContent = 'Guardando...';

            // → Recoger datos del formulario
            const payload = {
                Nombre        : document.getElementById('fNombre').value.trim(),
                Documento     : document.getElementById('fDocumento').value.trim(),
                TipoDocumento : document.getElementById('fTipoDoc').value,
                Rol           : document.getElementById('fRol').value,
                SaldoInicial  : parseFloat(document.getElementById('fSaldo').value) || 0
            };

            /*
             * → Leer el antiforgery token inyectado por Razor
             *   El campo tiene name="__RequestVerificationToken"
             */
            const tokenEl = document.querySelector('input[name="__RequestVerificationToken"]');
            const csrfToken = tokenEl ? tokenEl.value : '';

            try {
                /*
                 * ══════════════════════════════════════════════
                 * LLAMADA AL CONTROLADOR
                 *
                 * → Cambia la URL al endpoint real de tu app:
                 *   /Funcionario/AgregarUsuario
                 *
                 * → Si usas [FromBody]:  headers Content-Type: application/json
                 *                         body: JSON.stringify(payload)
                 * → Si usas [FromForm]:  elimina Content-Type y usa FormData
                 * ══════════════════════════════════════════════
                 */
                const response = await fetch('/Funcionario/AgregarUsuario', {
                    method : 'POST',
                    headers: {
                        'Content-Type'               : 'application/json',
                        'RequestVerificationToken'   : csrfToken   // header para antiforgery
                    },
                    body: JSON.stringify(payload)
                });

                /*
                 * → Parsear la respuesta JSON del servidor.
                 * → Espera un objeto tipo: { ok: bool, msg: string, usuario?: {...} }
                 */
                const data = await response.json();

                if (response.ok && data.ok) {
                    // ── Éxito ────────────────────────────────────────────
                    showToast('success', '¡Usuario creado!', data.msg || 'El usuario fue registrado correctamente.');

                    /*
                     * → Agregar el usuario a la tabla local.
                     * → Si el servidor devuelve el usuario creado (con ID de BD),
                     *   usa data.usuario en lugar del payload local.
                     */
                    payload.FechaAlta = new Date().toLocaleDateString('es-CO');
                    usuarios.push(payload);
                    renderTabla();

                    // → Limpiar el formulario
                    document.getElementById('formAgregarUsuario').reset();
                    document.getElementById('fSaldo').value = '0';

                } else {
                    // ── Error de negocio (ej. documento duplicado) ────────
                    showToast('error', 'Error al guardar', data.msg || 'Verifica los datos e intenta de nuevo.');
                }

            } catch (err) {
                /*
                 * → Error de red o excepción inesperada.
                 * → Loguear con console.error para diagnóstico en desarrollo.
                 */
                console.error('[SenaPay] Error fetch AgregarUsuario:', err);
                showToast('error', 'Error de conexión', 'No se pudo comunicar con el servidor. Verifica tu red.');
            } finally {
                // → Restaurar estado del botón siempre
                btn.disabled      = false;
                spinner.style.display = 'none';
                texto.textContent = 'Agregar usuario';
            }
        });

        /*
         * ─────────────────────────────────────────────────────────────
         * CARGA INICIAL DE USUARIOS (GET)
         *
         * Al cargar la vista, solicita los usuarios existentes al
         * servidor para poblar la tabla.
         *
         * Controlador sugerido:
         *   [HttpGet]
         *   public async Task<IActionResult> ObtenerUsuarios()
         *   {
         *       var lista = await _userService.GetAllAsync();
         *       return Ok(lista);
         *   }
         * ─────────────────────────────────────────────────────────────
         */
        async function cargarUsuariosIniciales() {
            try {
                const res  = await fetch('/Funcionario/ObtenerUsuarios');
                const data = await res.json();

                if (Array.isArray(data)) {
                    usuarios = data.map(u => ({
                        ...u,
                        FechaAlta: u.FechaAlta
                            ? new Date(u.FechaAlta).toLocaleDateString('es-CO')
                            : new Date().toLocaleDateString('es-CO')
                    }));
                    renderTabla();
                }
            } catch (err) {
                /*
                 * → En desarrollo, puede fallar si el endpoint no existe aún.
                 * → Simplemente mostramos la tabla vacía y seguimos.
                 */
                console.warn('[SenaPay] No se cargaron usuarios iniciales:', err.message);
                actualizarEstadisticas();
            }
        }

        // ── Init ──────────────────────────────────────────────────────
        document.addEventListener('DOMContentLoaded', () => {
            actualizarEstadisticas();
            cargarUsuariosIniciales(); // → comenta esta línea hasta tener el endpoint listo
        });
    </script>

</body>
</html>
