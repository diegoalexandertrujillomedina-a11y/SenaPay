@model NuevaPasswordViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>SenaPay | Nueva Contraseña</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@500;700;800&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0
        }

        :root {
            --c: #39A900;
            --cg: rgba(57,169,0,.18);
            --cr: rgba(57,169,0,.07);
            --speed: .55s
        }

        @@media (prefers-color-scheme: dark) {
            body {
                background: #060608;
            }

            .l-panel {
                background: #111114 !important;
                border-color: #222 !important;
            }

            .card {
                background: #1a1a1e !important;
                border-color: rgba(255,255,255,.05) !important;
                color: #fff;
            }

            .brand-text h1 {
                color: #fff !important;
            }

            .r-text h2 {
                color: #fff !important;
            }

            .form-control {
                background: #252529 !important;
                border-color: #333 !important;
                color: #eee !important;
            }

            .field-label {
                color: #64748b;
            }

            .card-footer {
                border-top-color: #252529;
            }

            .r-panel {
                background: #060608 !important;
            }

            .r-text p {
                color: rgba(255,255,255,.7);
            }

            .r-pill {
                color: rgba(255,255,255,.8) !important;
                background: rgba(255,255,255,.06) !important;
                border-color: rgba(255,255,255,.1) !important;
            }

            .r-overlay {
                background: radial-gradient(ellipse 65% 55% at 65% 35%,transparent,rgba(4,4,6,.6) 80%), linear-gradient(180deg,transparent 45%,rgba(4,4,6,.92)) !important;
            }

            .back-link {
                color: rgba(255,255,255,.45) !important;
            }

                .back-link:hover {
                    color: var(--c) !important;
                }

            .strength-bar-track {
                background: #252529 !important;
            }

            .req-item {
                color: rgba(255,255,255,.45) !important;
            }
        }

        body, html {
            height: 100%;
            overflow: hidden;
            font-family: 'Inter', sans-serif;
            background: #060608;
            -webkit-font-smoothing: antialiased
        }

        .shell {
            display: flex;
            height: 100vh
        }

        .l-panel {
            width: 42%;
            min-width: 420px;
            background: #fff;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            z-index: 20;
            padding: 40px 28px;
            overflow: hidden
        }

            .l-panel::after {
                content: '';
                position: absolute;
                right: -1px;
                top: 0;
                bottom: 0;
                width: 1px;
                background: linear-gradient(180deg,transparent,rgba(0,0,0,.07) 40%,rgba(0,0,0,.07) 60%,transparent)
            }

        .card-tilt {
            width: 100%;
            max-width: 400px;
            position: relative;
            z-index: 1;
            transform-style: preserve-3d;
            perspective: 900px;
            animation: slideUp .7s cubic-bezier(.22,1,.36,1) both
        }

        @@keyframes slideUp {
            from {
                opacity: 0;
                transform: translateY(32px)
            }

            to {
                opacity: 1;
                transform: translateY(0)
            }
        }

        .card {
            background: #fff;
            border-radius: 24px;
            padding: 36px 32px;
            box-shadow: 0 4px 24px rgba(0,0,0,.06), 0 1px 3px rgba(0,0,0,.04);
            border: 1px solid rgba(0,0,0,.045);
            transform-style: preserve-3d;
            will-change: transform
        }

        .brand-row {
            display: flex;
            align-items: center;
            gap: 14px;
            margin-bottom: 28px
        }

        .brand-icon {
            width: 52px;
            height: 52px;
            border-radius: 16px;
            background: var(--c);
            display: grid;
            place-items: center;
            color: #fff;
            font-size: 22px;
            flex-shrink: 0;
            box-shadow: 0 8px 24px var(--cg);
        }

        .brand-text h1 {
            font-family: 'Outfit', sans-serif;
            font-size: 1.75rem;
            font-weight: 800;
            color: #0f0f0f;
            line-height: 1;
            letter-spacing: -.5px
        }

        .brand-text span {
            font-size: .72rem;
            color: #94a3b8;
            letter-spacing: .5px;
            display: block;
            margin-top: 3px
        }

        .section-title {
            font-family: 'Outfit', sans-serif;
            font-size: .82rem;
            font-weight: 700;
            color: #64748b;
            text-transform: uppercase;
            letter-spacing: 1.4px;
            margin-bottom: 18px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

            .section-title::after {
                content: '';
                flex: 1;
                height: 1px;
                background: #f1f5f9;
            }

        .field-group {
            margin-bottom: 16px
        }

        .field-label {
            display: block;
            font-family: 'Outfit', sans-serif;
            font-size: .68rem;
            font-weight: 600;
            color: #94a3b8;
            text-transform: uppercase;
            letter-spacing: 1.2px;
            margin-bottom: 6px
        }

        .field-wrap {
            position: relative
        }

        .field-icon {
            position: absolute;
            left: 13px;
            top: 50%;
            transform: translateY(-50%);
            color: #c8d3dc;
            font-size: 14px;
            pointer-events: none;
            transition: color .3s
        }

        .toggle-pass {
            position: absolute;
            right: 13px;
            top: 50%;
            transform: translateY(-50%);
            color: #c8d3dc;
            font-size: 15px;
            cursor: pointer;
            transition: color .2s;
            border: none;
            background: none;
            padding: 0;
            line-height: 1;
        }

            .toggle-pass:hover {
                color: var(--c);
            }

        .form-control {
            width: 100%;
            padding: 13px 38px 13px 38px;
            border: 1.5px solid #edf0f4;
            border-radius: 12px;
            font-family: 'Inter', sans-serif;
            font-size: .88rem;
            color: #1e293b;
            background: #fafbfc;
            appearance: none;
            outline: none;
            transition: border-color .25s, box-shadow .25s
        }

            .form-control:focus {
                border-color: var(--c);
                box-shadow: 0 0 0 3.5px var(--cr);
                background: #fff
            }

            .form-control.is-match {
                border-color: var(--c);
            }

            .form-control.is-mismatch {
                border-color: #ef4444;
                box-shadow: 0 0 0 3.5px rgba(239,68,68,.07);
            }

        .alert-ui {
            font-size: 0.72rem;
            color: #ef4444;
            margin-top: 5px;
            display: none;
            align-items: center;
            gap: 4px;
            font-weight: 500;
        }

        /* ── Barra de fortaleza ── */
        .strength-wrap {
            margin-top: 8px
        }

        .strength-bar-track {
            height: 4px;
            border-radius: 99px;
            background: #f1f5f9;
            overflow: hidden;
            margin-bottom: 5px;
        }

        .strength-bar-fill {
            height: 100%;
            border-radius: 99px;
            width: 0%;
            transition: width .4s ease, background .4s ease;
        }

        .strength-label {
            font-family: 'Outfit', sans-serif;
            font-size: .68rem;
            font-weight: 600;
            letter-spacing: .6px;
            color: #94a3b8;
            transition: color .3s;
        }

        /* ── Requisitos de contraseña ── */
        .req-list {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 5px 12px;
            margin-top: 10px;
            margin-bottom: 4px;
        }

        .req-item {
            font-size: .68rem;
            color: #94a3b8;
            display: flex;
            align-items: center;
            gap: 5px;
            font-family: 'Outfit', sans-serif;
            font-weight: 500;
            transition: color .25s;
        }

            .req-item i {
                font-size: 10px;
                transition: color .25s;
            }

            .req-item.ok {
                color: var(--c);
            }

                .req-item.ok i {
                    color: var(--c);
                }

        .btn-submit {
            width: 100%;
            padding: 15px 20px;
            border: none;
            border-radius: 14px;
            background: var(--c);
            color: #fff;
            font-family: 'Outfit', sans-serif;
            font-size: .82rem;
            font-weight: 600;
            letter-spacing: 1.8px;
            text-transform: uppercase;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-top: 20px;
            box-shadow: 0 10px 30px var(--cg);
            transition: all var(--speed);
            position: relative;
            overflow: hidden
        }

            .btn-submit:disabled {
                opacity: 0.7;
                cursor: not-allowed;
                filter: grayscale(0.5);
            }

        .btn-arrow {
            width: 28px;
            height: 28px;
            border-radius: 9px;
            background: rgba(255,255,255,.2);
            display: grid;
            place-items: center;
            font-size: 14px;
        }

        .card-footer {
            margin-top: 24px;
            padding-top: 18px;
            border-top: 1px solid #f1f5f9;
            display: flex;
            flex-direction: column;
            gap: 12px
        }

        .back-link {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            font-size: .72rem;
            color: #94a3b8;
            text-decoration: none;
            transition: color .2s;
            font-family: 'Outfit', sans-serif;
            font-weight: 600;
        }

            .back-link:hover {
                color: var(--c);
            }

        /* Panel derecho */
        .r-panel {
            flex: 1;
            position: relative;
            background: #f8fafc;
            overflow: hidden;
            display: flex;
            align-items: flex-end
        }

        #geo-canvas {
            position: absolute;
            inset: 0;
            width: 100%;
            height: 100%;
            z-index: 1
        }

        .r-spotlight {
            position: absolute;
            inset: 0;
            z-index: 2;
            pointer-events: none
        }

        .r-overlay {
            position: absolute;
            inset: 0;
            z-index: 3;
            pointer-events: none;
            background: radial-gradient(ellipse 65% 55% at 65% 35%,transparent,rgba(255,255,255,.4) 80%), linear-gradient(180deg,transparent 45%,rgba(255,255,255,.95))
        }

        .r-text {
            position: relative;
            z-index: 5;
            padding: 52px 56px;
            max-width: 520px;
            margin-bottom: 40px;
        }

            .r-text p {
                color: #64748b;
            }

        .r-pill {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            background: rgba(0,0,0,.04);
            border: 1px solid rgba(0,0,0,.08);
            border-radius: 100px;
            padding: 6px 14px 6px 8px;
            font-size: .72rem;
            color: #475569;
            backdrop-filter: blur(8px);
            margin-bottom: 20px
        }

        .r-pill-dot {
            width: 7px;
            height: 7px;
            border-radius: 50%;
            background: var(--c);
            box-shadow: 0 0 8px var(--c);
            animation: sPulse 2s infinite
        }

        .r-text h2 {
            font-family: 'Outfit', sans-serif;
            font-size: clamp(2rem,3vw,2.9rem);
            font-weight: 800;
            color: #0f0f0f;
            line-height: 1.1;
            letter-spacing: -1px;
            margin-bottom: 14px
        }

            .r-text h2 em {
                font-style: normal;
                color: var(--c);
            }

        @@keyframes sPulse {
            0%, 100% {
                box-shadow: 0 0 0 0 rgba(34,197,94,.45)
            }

            55% {
                box-shadow: 0 0 0 5px rgba(34,197,94,0)
            }
        }

        @@keyframes rip {
            to {
                transform: scale(2.5);
                opacity: 0
            }
        }
    </style>
</head>
<body>

    <div class="shell">

        <!-- ===== PANEL IZQUIERDO ===== -->
        <div class="l-panel" id="lPanel">
            <div class="card-tilt" id="tiltWrap">
                <div class="card">

                    <div class="brand-row">
                        <div class="brand-icon">
                            <i class="bi bi-lock-fill"></i>
                        </div>
                        <div class="brand-text">
                            <h1>SenaPay</h1>
                            <span>Nueva contraseña</span>
                        </div>
                    </div>

                    <div class="section-title">
                        <i class="bi bi-key-fill" style="font-size:12px;color:var(--c)"></i>
                        Establece tu nueva contraseña
                    </div>

                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div style="font-size:.76rem;color:#ef4444;background:rgba(239,68,68,.07);border:1px solid rgba(239,68,68,.15);border-radius:10px;padding:10px 12px;margin-bottom:16px;display:flex;align-items:center;gap:6px;font-weight:500;">
                            <i class="bi bi-exclamation-circle-fill"></i>
                            @Html.ValidationSummary(true)
                        </div>
                    }

                    <form asp-action="NuevaPassword" method="post" id="passForm" onsubmit="return validateForm(event)">
                        @Html.AntiForgeryToken()

                        <!-- Nueva contraseña -->
                        <div class="field-group">
                            <label class="field-label" asp-for="NuevaPassword">Nueva contraseña</label>
                            <div class="field-wrap">
                                <i class="bi bi-lock field-icon"></i>
                                <input asp-for="NuevaPassword"
                                       type="password"
                                       class="form-control"
                                       id="passField"
                                       placeholder="••••••••"
                                       autocomplete="new-password"
                                       oninput="evalStrength(this.value)" />
                                <button type="button" class="toggle-pass" onclick="togglePass('passField', this)" tabindex="-1">
                                    <i class="bi bi-eye-slash"></i>
                                </button>
                            </div>
                            <div id="err-pass" class="alert-ui">
                                <i class="bi bi-exclamation-circle"></i> La contraseña debe cumplir los requisitos
                            </div>
                            <span asp-validation-for="NuevaPassword" style="font-size:.72rem;color:#ef4444;margin-top:4px;display:block;"></span>

                            <!-- Barra de fortaleza -->
                            <div class="strength-wrap">
                                <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:4px;">
                                    <span class="strength-label" id="strengthLabel">Sin contraseña</span>
                                </div>
                                <div class="strength-bar-track">
                                    <div class="strength-bar-fill" id="strengthBar"></div>
                                </div>
                            </div>

                            <!-- Requisitos -->
                            <div class="req-list">
                                <div class="req-item" id="req-len">
                                    <i class="bi bi-circle"></i> Mín. 8 caracteres
                                </div>
                                <div class="req-item" id="req-upper">
                                    <i class="bi bi-circle"></i> Una mayúscula
                                </div>
                                <div class="req-item" id="req-num">
                                    <i class="bi bi-circle"></i> Un número
                                </div>
                                <div class="req-item" id="req-special">
                                    <i class="bi bi-circle"></i> Un símbolo
                                </div>
                            </div>
                        </div>

                        <!-- Confirmar contraseña -->
                        <div class="field-group">
                            <label class="field-label" asp-for="ConfirmarPassword">Confirmar contraseña</label>
                            <div class="field-wrap">
                                <i class="bi bi-lock-fill field-icon"></i>
                                <input asp-for="ConfirmarPassword"
                                       type="password"
                                       class="form-control"
                                       id="confirmField"
                                       placeholder="••••••••"
                                       autocomplete="new-password"
                                       oninput="checkMatch()" />
                                <button type="button" class="toggle-pass" onclick="togglePass('confirmField', this)" tabindex="-1">
                                    <i class="bi bi-eye-slash"></i>
                                </button>
                            </div>
                            <div id="err-confirm" class="alert-ui">
                                <i class="bi bi-exclamation-circle"></i> Las contraseñas no coinciden
                            </div>
                            <span asp-validation-for="ConfirmarPassword" style="font-size:.72rem;color:#ef4444;margin-top:4px;display:block;"></span>
                        </div>

                        <button type="submit" class="btn-submit" id="submitBtn" onclick="btnRipple(event)">
                            <span id="btnText">Guardar contraseña</span>
                            <div class="btn-arrow"><i class="bi bi-floppy-fill"></i></div>
                        </button>

                    </form>

                    <div class="card-footer">
                        <div style="text-align:center;">
                            <a asp-controller="Account" asp-action="CodVerificacion" class="back-link">
                                <i class="bi bi-arrow-left"></i> Volver al paso anterior
                            </a>
                        </div>
                        <div style="display:flex;justify-content:space-between;align-items:center;">
                            <div style="font-size:.72rem;color:#cbd5e1">By <strong>CTA S.S.C</strong></div>
                            <div style="display:flex;align-items:center;gap:5px;font-size:.68rem;color:#94a3b8">
                                <div style="width:6px;height:6px;border-radius:50%;background:#22c55e"></div>
                                SSL Seguro
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </div>

        <!-- ===== PANEL DERECHO ===== -->
        <div class="r-panel" id="rPanel">
            <svg id="geo-canvas" xmlns="http://www.w3.org/2000/svg"></svg>
            <div class="r-spotlight"></div>
            <div class="r-overlay"></div>
            <div class="r-text">
                <div class="r-pill">
                    <div class="r-pill-dot"></div> SENA · Colombia
                </div>
                <h2>Crea una<br><em>clave segura</em></h2>
                <p>Elige una contraseña fuerte que proteja tu cuenta. Te recomendamos usar letras, números y símbolos.</p>
            </div>
        </div>

    </div>

    <script>
        /* ── Mostrar / ocultar contraseña ── */
        function togglePass(fieldId, btn) {
            var f = document.getElementById(fieldId);
            var icon = btn.querySelector('i');
            if (f.type === 'password') {
                f.type = 'text';
                icon.className = 'bi bi-eye';
            } else {
                f.type = 'password';
                icon.className = 'bi bi-eye-slash';
            }
        }

        /* ── Evaluador de fortaleza ── */
        var rules = {
            len:     function(v) { return v.length >= 8; },
            upper:   function(v) { return /[A-Z]/.test(v); },
            num:     function(v) { return /\d/.test(v); },
            special: function(v) { return /[^A-Za-z0-9]/.test(v); }
        };

        var strengthCfg = [
            { label: 'Muy débil',  color: '#ef4444', pct: '15%'  },
            { label: 'Débil',      color: '#f97316', pct: '35%'  },
            { label: 'Aceptable',  color: '#eab308', pct: '60%'  },
            { label: 'Fuerte',     color: '#22c55e', pct: '80%'  },
            { label: 'Muy fuerte', color: '#39A900', pct: '100%' }
        ];

        function evalStrength(val) {
            var score = 0;
            Object.keys(rules).forEach(function(key) {
                var met = rules[key](val);
                score += met ? 1 : 0;
                var el = document.getElementById('req-' + key);
                var icon = el.querySelector('i');
                if (met) {
                    el.classList.add('ok');
                    icon.className = 'bi bi-check-circle-fill';
                } else {
                    el.classList.remove('ok');
                    icon.className = 'bi bi-circle';
                }
            });

            var bar   = document.getElementById('strengthBar');
            var label = document.getElementById('strengthLabel');

            if (!val) {
                bar.style.width = '0%';
                label.textContent = 'Sin contraseña';
                label.style.color = '#94a3b8';
                return;
            }

            var cfg = strengthCfg[score - 1] || strengthCfg[0];
            bar.style.width      = cfg.pct;
            bar.style.background = cfg.color;
            label.textContent    = cfg.label;
            label.style.color    = cfg.color;

            // Retestar coincidencia si ya hay algo escrito en confirmar
            if (document.getElementById('confirmField').value) checkMatch();
        }

        /* ── Verificar coincidencia ── */
        function checkMatch() {
            var p1 = document.getElementById('passField').value;
            var p2 = document.getElementById('confirmField').value;
            var cf = document.getElementById('confirmField');
            if (!p2) {
                cf.classList.remove('is-match', 'is-mismatch');
                document.getElementById('err-confirm').style.display = 'none';
                return;
            }
            if (p1 === p2) {
                cf.classList.add('is-match');
                cf.classList.remove('is-mismatch');
                document.getElementById('err-confirm').style.display = 'none';
            } else {
                cf.classList.add('is-mismatch');
                cf.classList.remove('is-match');
                document.getElementById('err-confirm').style.display = 'flex';
            }
        }

        /* ── Validación antes de enviar ── */
        function validateForm(e) {
            var pass    = document.getElementById('passField').value;
            var confirm = document.getElementById('confirmField').value;
            var valid   = true;

            // Todos los requisitos deben cumplirse
            var allMet = Object.keys(rules).every(function(k) { return rules[k](pass); });
            if (!pass || !allMet) {
                document.getElementById('err-pass').style.display = 'flex';
                valid = false;
            } else {
                document.getElementById('err-pass').style.display = 'none';
            }

            if (pass !== confirm || !confirm) {
                document.getElementById('err-confirm').style.display = 'flex';
                document.getElementById('confirmField').classList.add('is-mismatch');
                valid = false;
            }

            if (valid) {
                if (!window.navigator.onLine) {
                    alert('No tienes conexión a internet.');
                    return false;
                }
                var btn = document.getElementById('submitBtn');
                btn.disabled = true;
                document.getElementById('btnText').innerText = 'Guardando...';
            }
            return valid;
        }

        /* ── Tilt card ── */
        var tiltWrap = document.getElementById('tiltWrap');
        var tx = 0, ty = 0, ttx = 0, tty = 0;

        document.getElementById('lPanel').addEventListener('mousemove', function (e) {
            var r = tiltWrap.getBoundingClientRect();
            ttx = (e.clientY - r.top  - r.height / 2) / r.height * -9;
            tty = (e.clientX - r.left - r.width  / 2) / r.width  *  9;
        });

        document.getElementById('lPanel').addEventListener('mouseleave', function () {
            ttx = 0; tty = 0;
        });

        function lerp(a, b, t) { return a + (b - a) * t; }

        (function loop() {
            tx = lerp(tx, ttx, .08);
            ty = lerp(ty, tty, .08);
            tiltWrap.style.transform =
                'perspective(900px) rotateX(' + tx.toFixed(2) + 'deg) rotateY(' + ty.toFixed(2) + 'deg)';
            requestAnimationFrame(loop);
        })();

        /* ── Ripple en botón ── */
        function btnRipple(e) {
            var r  = e.currentTarget.getBoundingClientRect();
            var sp = document.createElement('span');
            sp.style.cssText =
                'position:absolute;background:rgba(255,255,255,.3);border-radius:50%;'
                + 'width:100px;height:100px;'
                + 'left:' + (e.clientX - r.left - 50) + 'px;'
                + 'top:'  + (e.clientY - r.top  - 50) + 'px;'
                + 'transform:scale(0);animation:rip .6s ease-out';
            e.currentTarget.appendChild(sp);
            setTimeout(function () { sp.remove(); }, 600);
        }
    </script>

    @section Scripts {
        @{
            await Html.RenderPartialAsync("_ValidationScriptsPartial");
        }
    }

</body>
</html>